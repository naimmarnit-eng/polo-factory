---
// Base layout — ใช้เป็นโครงหลักของทุกหน้า
import '@/styles/global.css';
import SEO from '@/components/SEO.astro';
import { SITE } from '@/consts';
import favicon from '@/assets/favicon.png';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, image, type, noindex, jsonLd } = Astro.props;
---

<!doctype html>
<html lang={SITE.lang} class="motion-safe:scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <meta name="generator" content={Astro.generator} />
    {/* Analytics: Ahrefs — async + preconnect (สคริปต์เบา โหลด early ได้, ช่วย LCP ~150ms) */}
    <link rel="preconnect" href="https://analytics.ahrefs.com" crossorigin />
    <script src="https://analytics.ahrefs.com/analytics.js" data-key="qtnb/p0ltu4tTRRtzqv54g" async></script>
    {/* Google tag (gtag.js) — เลื่อนโหลดจนผู้ใช้ interact ครั้งแรกหรือเมื่อ idle
        เพื่อลด main-thread work / TBT ตอนโหลดหน้า */}
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        // eslint-disable-next-line prefer-rest-params -- สคริปต์ gtag มาตรฐานของ Google ต้อง push `arguments` (เปลี่ยนเป็น rest params จะพัง GA)
        dataLayer.push(arguments);
      }
      function loadGtag() {
        if (window.__gtagLoaded) return;
        window.__gtagLoaded = true;
        const s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-LHS945KVZM';
        document.head.appendChild(s);
        gtag('js', new Date());
        gtag('config', 'G-LHS945KVZM');
      }
      ['scroll', 'pointerdown', 'keydown', 'touchstart'].forEach(function (evt) {
        addEventListener(evt, loadGtag, { once: true, passive: true });
      });
      if (window.requestIdleCallback) {
        requestIdleCallback(loadGtag, { timeout: 5000 });
      } else {
        setTimeout(loadGtag, 5000);
      }
    </script>

    {/* Microsoft Clarity — heatmaps + session recordings (โหลด async เอง ไม่บล็อก render) */}
    <link rel="preconnect" href="https://www.clarity.ms" crossorigin />
    <script is:inline>
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            // eslint-disable-next-line prefer-rest-params -- โค้ด snippet มาตรฐานของ Microsoft Clarity ต้อง push `arguments` (เปลี่ยนเป็น rest params เสี่ยง queue event พัง)
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = 'https://www.clarity.ms/tag/' + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, 'clarity', 'script', 'x5q5tvdd8n');
    </script>

    {/* RSS feed discovery */}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.name}
      href={new URL('rss.xml', Astro.site)}
    />

    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
    />

    {/* Astro Client Router to enable seamless page transition animations */}
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    {/* Scroll Progress Bar at the top of the page */}
    <div id="scroll-progress" aria-hidden="true"></div>
    <slot />

    {/* Scroll Reveal Animation script */}
    <script>
      function initScrollReveal() {
        const revealElements = document.querySelectorAll(
          '.reveal, .reveal-up, .reveal-left, .reveal-right, .reveal-scale, .reveal-fade, .reveal-blur, .reveal-skew'
        );

        if (revealElements.length === 0) return;

        // Immediately show if user prefers reduced motion
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReducedMotion) {
          revealElements.forEach((el) => el.classList.add('active'));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('active');
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.05,
            rootMargin: '0px 0px -40px 0px',
          }
        );

        revealElements.forEach((el) => {
          observer.observe(el);
        });
      }

      function initScrollProgress() {
        const progressBar = document.getElementById('scroll-progress');
        if (!progressBar) return;

        function updateProgress() {
          const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
          const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
          progressBar.style.width = scrolled + '%';
        }

        window.addEventListener('scroll', updateProgress, { passive: true });
        updateProgress(); // run once on init
      }

      function initAll() {
        initScrollReveal();
        initScrollProgress();
      }

      // Initialize on load and on page navigation (Astro transitions support)
      document.addEventListener('astro:page-load', initAll);
      
      // Fallback
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAll);
      } else {
        initAll();
      }
    </script>
  </body>
</html>
