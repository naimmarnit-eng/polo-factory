---
// Page layout — กรอบการ์ดหลักของทุกหน้า (Navbar + กรอบขาว + main)
// ใช้ครอบ Layout (โครง HTML/SEO) เพื่อให้ระยะขอบทุกหน้าเท่ากัน
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import FloatingContact from '@/components/FloatingContact.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** คลาสของ <main> — override padding เฉพาะหน้าได้ (เช่นหน้า 404 จัดกึ่งกลาง) */
  mainClass?: string;
}

const {
  mainClass = 'px-4 sm:px-8 lg:px-12 pt-28 pb-20',
  ...seo
} = Astro.props;
---

<Layout {...seo}>
  <div class="min-h-screen bg-[#FAFAFA] font-sans flex flex-col">
    <Navbar />
    <div class="w-full max-w-[1400px] mx-auto flex-grow relative">
      <main class={mainClass}>
        <slot />
      </main>
    </div>
    <Footer />
  </div>
  <FloatingContact />
</Layout>

