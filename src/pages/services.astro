---
// หน้าบริการ /services — ปลายทางของลิงก์ Services บน Navbar
// ประกอบด้วยคอมโพเนนต์ใหม่ (services/*) ทั้งหมด เพื่อเพิ่มเอกลักษณ์เฉพาะของหน้าบริการ
// พร้อมปรับปรุงข้อมูลโครงสร้าง SEO (JSON-LD) ให้สอดคล้องกับช่องทางการติดต่อจริง
import PageLayout from '@/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import ServicesHero from '@/components/services/ServicesHero.astro';
import ServiceGrid from '@/components/services/ServiceGrid.astro';
import ServicePrinting from '@/components/services/ServicePrinting.astro';
import ServiceProcess from '@/components/services/ServiceProcess.astro';
import ServiceWhyChooseUs from '@/components/services/ServiceWhyChooseUs.astro';
import ServicePrivileges from '@/components/services/ServicePrivileges.astro';
import ServiceCta from '@/components/services/ServiceCta.astro';
import Faq from '@/components/Faq.astro';
import { buildFaqJsonLd, type FaqItem } from '@/lib/faq';
import { SERVICES } from '@/lib/services';
import { SITE } from '@/consts';
import logo from '@/assets/logo.png';

// URL หน้านี้ (absolute, ลงท้าย / ให้ตรง canonical) — ใช้ใน JSON-LD ของ Service และ Breadcrumb
const pageUrl = new URL('/services/', Astro.site).toString();
// @id ของ Organization กลาง (ออกทุกหน้าจาก SEO.astro) — อ้างผูก LocalBusiness ให้เป็น entity เดียวกัน
const orgId = new URL('/#organization', Astro.site).toString();

// จำนวนผลงานจริงสำหรับโชว์เป็นสถิติใน hero
const works = (await getCollection('products')).length;

// FAQ เฉพาะหน้าบริการ — แหล่งข้อมูลชุดเดียว ป้อนทั้ง accordion + FAQPage JSON-LD
const faqItems: FaqItem[] = [
  {
    question: 'รับผลิตเสื้อขั้นต่ำกี่ตัว?',
    answer:
      'ยอดสั่งผลิตขั้นต่ำยืดหยุ่นตามชนิดงานและเทคนิคที่เลือก งานพิมพ์ดิจิทัล (DTG/DTF) เริ่มผลิตจำนวนน้อยได้ ส่วนงานซิลค์สกรีนจะคุ้มค่าเมื่อสั่งจำนวนมาก ทักมาปรึกษาเพื่อให้ทีมงานแนะนำทางที่เหมาะกับงบและจำนวนของคุณได้เลย',
  },
  {
    question: 'ใช้เวลาผลิตนานแค่ไหน?',
    answer:
      'ระยะเวลาขึ้นอยู่กับจำนวน เทคนิคงานพิมพ์ และความซับซ้อนของแบบ โดยทั่วไปเราจะแจ้งกำหนดส่งที่ชัดเจนพร้อมใบเสนอราคา และควบคุมการผลิตให้ตรงเวลาตามมาตรฐาน QPC (Quality, Price, Control)',
  },
  {
    question: 'ควรเลือกซิลค์สกรีนหรือ DTG/DTF ดี?',
    answer:
      'ถ้าลายมีไม่กี่สีและสั่งจำนวนมาก ซิลค์สกรีนจะให้สีสดทนทานและต้นทุนต่อตัวต่ำกว่า แต่ถ้าลายมีหลายสี เป็นภาพถ่าย หรือสั่งจำนวนน้อย งานพิมพ์ดิจิทัล DTG/DTF จะเก็บรายละเอียดได้ดีกว่าโดยไม่ต้องทำบล็อกสกรีน ทีมงานช่วยแนะนำให้ตามลายและจำนวนที่ต้องการ',
  },
  {
    question: 'มีบริการออกแบบให้ไหม คิดเงินเพิ่มหรือเปล่า?',
    answer:
      'มีบริการออกแบบฟรี (Design Free) ทีมดีไซน์ช่วยขึ้นแบบ จัดวางลาย และปรับแก้ให้จนพอใจก่อนเริ่มผลิตจริง พร้อมให้คำปรึกษาทุกขั้นตอนโดยไม่มีค่าใช้จ่ายเพิ่ม',
  },
  {
    question: 'รับผลิตเสื้อประเภทไหนบ้าง?',
    answer:
      'รับผลิตเสื้อยืด เสื้อโปโล แจ็คเก็ต เสื้อช็อป รวมถึงกระเป๋าผ้า ครบวงจรตั้งแต่เลือกเนื้อผ้า ตัดเย็บ ไปจนถึงงานสกรีนและงานพิมพ์ทุกเทคนิค',
  },
  {
    question: 'ขอใบเสนอราคาได้อย่างไร?',
    answer:
      'เพียงทักเข้ามาแจ้งแบบเสื้อ จำนวน และลวดลายที่ต้องการ ทีมงานจะช่วยประเมินราคา แนะนำเนื้อผ้าและเทคนิคสกรีน พร้อมส่งใบเสนอราคาและออกแบบให้ดูก่อนตัดสินใจ',
  },
  {
    question: 'ต้องเตรียมไฟล์ลายสกรีนแบบไหน?',
    answer:
      'ไฟล์เวกเตอร์ (AI, EPS, PDF) คมชัดที่สุดเพราะขยายได้ไม่แตก หากเป็นไฟล์ภาพ (PNG/JPG) ควรความละเอียดสูงอย่างน้อย 300 dpi เท่าขนาดที่จะพิมพ์จริง ถ้ายังไม่มีไฟล์พร้อม ทีมออกแบบช่วยจัดทำและเกลาไฟล์ให้ฟรีก่อนผลิต',
  },
  {
    question: 'สกรีนได้กี่สี มีค่าใช้จ่ายต่อสีไหม?',
    answer:
      'งานซิลค์สกรีนคิดต้นทุนตามจำนวนสี (แยกบล็อกต่อสี) ลายไม่กี่สีจึงคุ้มสุด ส่วนงานพิมพ์ดิจิทัล DTG/DTF พิมพ์ได้หลายสีหรือภาพไล่เฉดในครั้งเดียวโดยไม่คิดเพิ่มตามจำนวนสี ทีมงานจะแนะนำเทคนิคที่คุ้มที่สุดตามลายและจำนวนของคุณ',
  },
  {
    question: 'มีบริการทำตัวอย่าง (sample) ก่อนผลิตจริงไหม?',
    answer:
      'มี เราแนะนำให้ดูแบบดิจิทัล (mockup) ทุกงานก่อนเริ่มผลิต และทำตัวอย่างจริงก่อนเดินสายการผลิตได้สำหรับงานจำนวนมาก เพื่อยืนยันเนื้อผ้า สี และตำแหน่งสกรีนให้ตรงใจก่อนผลิตเต็มล็อต',
  },
  {
    question: 'รับงานปักโลโก้ไหม ต่างจากสกรีนอย่างไร?',
    answer:
      'รับงานปักด้วย งานปักให้สัมผัสพรีเมียมและทนทานมาก เหมาะกับโลโก้บนเสื้อโปโล แจ็คเก็ต และยูนิฟอร์มองค์กร ส่วนงานสกรีน/DTF เก็บรายละเอียดลายใหญ่และไล่เฉดสีได้ดีกว่าในต้นทุนที่ถูกกว่า เลือกตามชิ้นงานและภาพลักษณ์ที่ต้องการ',
  },
  {
    question: 'เลือกไซซ์และทรงเสื้อได้แค่ไหน?',
    answer:
      'มีให้เลือกตั้งแต่ไซซ์เด็กถึงผู้ใหญ่ (S–5XL) หลายทรงทั้งคอกลม คอวี โอเวอร์ไซส์ และทรงเข้ารูป สั่งตัดแพทเทิร์นเฉพาะหรือปรับสัดส่วนตามต้องการได้สำหรับงานสั่งผลิต ทีมงานมีเสื้อตัวอย่างให้ลองไซซ์ก่อนสรุปแบบ',
  },
  {
    question: 'ราคาเริ่มต้นเท่าไร คิดราคาอย่างไร?',
    answer:
      'ราคาต่อตัวขึ้นกับชนิดผ้า จำนวน เทคนิคงานพิมพ์ และจำนวนจุด/สีที่สกรีน ยิ่งสั่งจำนวนมากต้นทุนต่อตัวยิ่งลด ทุกงานมีใบเสนอราคาชัดเจนก่อนเริ่มผลิต ไม่มีค่าใช้จ่ายแอบแฝง และออกแบบให้ฟรี',
  },
  {
    question: 'มีโปรโมชันหรือสิทธิพิเศษอะไรบ้าง?',
    answer:
      'ออกแบบฟรีทุกงาน, สกรีนฟรี 1 สี 1 จุด เมื่อสั่งผลิตครบ 100 ตัว และส่งฟรีในเขตกรุงเทพฯ เมื่อมียอดสั่งครบ 20,000 บาท พร้อมให้คำปรึกษาฟรีทุกขั้นตอน',
  },
  {
    question: 'จัดส่งทั่วประเทศไหม คิดค่าส่งอย่างไร?',
    answer:
      'จัดส่งทั่วประเทศผ่านขนส่งมาตรฐาน ค่าส่งคิดตามน้ำหนักและปลายทาง ส่งฟรีในเขตกรุงเทพฯ เมื่อมียอดสั่งครบ 20,000 บาท ทีมงานแจ้งกำหนดส่งที่ชัดเจนพร้อมใบเสนอราคา',
  },
  {
    question: 'ชำระเงินอย่างไร ต้องวางมัดจำไหม?',
    answer:
      'โดยทั่วไปวางมัดจำส่วนหนึ่งก่อนเริ่มผลิต และชำระส่วนที่เหลือเมื่องานเสร็จก่อนจัดส่ง รองรับการโอนผ่านธนาคาร เงื่อนไขการชำระและมัดจำที่แน่นอนจะระบุไว้ในใบเสนอราคาของแต่ละงาน',
  },
];

const faqJsonLd = buildFaqJsonLd(faqItems);

// Service JSON-LD — อธิบายบริการของโรงงานสำหรับ search/LLM crawler
// hasOfferCatalog สร้างจาก SERVICES ชุดเดียวกับ ServiceGrid → ตรงกับที่เห็นบนหน้าเสมอ
// provider ใช้โครงสร้างของ LocalBusiness เพื่อระบุเบอร์โทรศัพท์ อีเมล และที่อยู่อย่างชัดเจน
const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'รับผลิตเสื้อ สกรีน และงานพิมพ์ผ้าครบวงจร',
  name: 'บริการรับผลิตเสื้อครบวงจร',
  description: SITE.description,
  url: pageUrl,
  provider: {
    '@type': 'LocalBusiness',
    // @id เดียวกับ Organization กลาง → Google/LLM รวมเป็น entity เดียว (ไม่แตกเป็นสองก้อน)
    '@id': orgId,
    name: SITE.name,
    // ชื่อนิติบุคคล + ชื่อพ้อง ให้ตรงกับ Organization กลาง (entity เดียวกัน)
    legalName: 'บริษัท ธน พลัส 153 จำกัด',
    alternateName: ['ธน พลัส 153', 'Thana Plus 153'],
    // โลโก้แบรนด์จริงผ่าน astro:assets (.src = path ที่ hash จริง) — เดิมชี้ /favicon.png ที่ 404
    image: new URL(logo.src, Astro.site).toString(),
    url: Astro.site?.toString(),
    telephone: SITE.contact.phone,
    email: SITE.contact.email,
    sameAs: [SITE.contact.lineLink],
    address: {
      '@type': 'PostalAddress',
      streetAddress: '503 ถนนสุโขทัย แขวงสวนจิตรลดา',
      addressLocality: 'เขตดุสิต',
      addressRegion: 'กรุงเทพมหานคร',
      postalCode: '10300',
      addressCountry: 'TH',
    },
    priceRange: '$$',
  },
  areaServed: { '@type': 'Country', name: 'Thailand' },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'บริการรับผลิตเสื้อ',
    itemListElement: SERVICES.map((s) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: s.title,
        description: s.description,
      },
    })),
  },
};

// Breadcrumb JSON-LD — หน้าแรก → บริการของเรา
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: Astro.site?.toString() },
    { '@type': 'ListItem', position: 2, name: 'บริการของเรา', item: pageUrl },
  ],
};

// รวม JSON-LD ทั้งหมด (กรอง null ของ FAQ ออก)
const jsonLd = [serviceJsonLd, breadcrumbJsonLd, ...(faqJsonLd ? [faqJsonLd] : [])];
---

<PageLayout
  title="โรงงานผลิตเสื้อผ้า รับผลิตเสื้อครบวงจร สกรีน ออกแบบฟรี"
  description="โรงงานผลิตเสื้อผ้าครบวงจร เสื้อแท้ รับผลิตเสื้อยืด โปโล แจ็คเก็ต ตั้งแต่เลือกผ้า ตัดเย็บ ออกแบบฟรี งานซิลค์สกรีนและ DTG/DTF พร้อมขอใบเสนอราคาฟรี"
  jsonLd={jsonLd}
>
  <ServicesHero works={works} />
  <ServiceGrid />
  <ServicePrinting />
  <ServiceProcess />
  <ServiceWhyChooseUs />
  <ServicePrivileges />
  <Faq
    items={faqItems}
    title="คำถามที่พบบ่อยเกี่ยวกับบริการ"
    class="mt-24 lg:mt-32 max-w-4xl mx-auto"
  />
  <ServiceCta />
</PageLayout>
