---
// หน้าบริการ /services — ปลายทางของลิงก์ Services บน Navbar
// ประกอบด้วยการจัดหน้าแบบผสมผสานสไตล์อุตสาหกรรมพรีเมียม (Redesigned completely)
import PageLayout from '@/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Faq from '@/components/Faq.astro';
import { buildFaqJsonLd, type FaqItem } from '@/lib/faq';
import { SERVICES, PRIVILEGES, WHY_CHOOSE_US } from '@/lib/services';
import { SITE } from '@/consts';
import logo from '@/assets/logo.png';

// นำเข้ารูปภาพสำหรับเทคนิคงานสกรีน
import silkScreenImg from '@/assets/home/ScreenServices/Silk Screen.png';
import dftDtgImg from '@/assets/home/ScreenServices/DFT_DTG.png';
import sublimationImg from '@/assets/home/ScreenServices/Sublimation.png';

// นำเข้ารูปภาพประกอบของโรงงาน
import whyChooseImg from '@/assets/home/WhyChooseUsHover.png';
import whyChooseOverlay from '@/assets/home/WhyChooseUs.png';



// URL หน้านี้ (absolute, ลงท้าย / ให้ตรง canonical) — ใช้ใน JSON-LD ของ Service และ Breadcrumb
const pageUrl = new URL('/services/', Astro.site).toString();
const orgId = new URL('/#organization', Astro.site).toString();

// จำนวนผลงานจริงสำหรับโชว์เป็นสถิติใน hero
const works = (await getCollection('products')).length;

// FAQ เฉพาะหน้าบริการ
const faqItems: FaqItem[] = [
  {
    question: 'รับผลิตเสื้อขั้นต่ำกี่ตัว?',
    answer:
      'ยอดสั่งผลิตขั้นต่ำยืดหยุ่นตามชนิดงานและเทคนิคที่เลือก งานพิมพ์ดิจิทัล (DTG/DTF) เริ่มผลิตจำนวนน้อยได้ ส่วนงานซิลค์สกรีนจะคุ้มค่าเมื่อสั่งจำนวนมาก ทักมาปรึกษาเพื่อให้ทีมงานแนะนำทางที่เหมาะกับงบและจำนวนของคุณได้เลย',
  },
  {
    question: 'ใช้เวลาผลิตนานแค่ไหน?',
    answer:
      'ระยะเวลาขึ้นอยู่กับจำนวน เทคนิคงานพิมพ์ และความซับซ้อนของแบบ โดยทั่วไปเราจะแจ้งกำหนดส่งที่ชัดเจนพร้อมใบเสนอราคา และควบคุมการผลิตให้ตรงเวลาตามมาตรฐาน QPC (Quality, Price, Control)',
  },
  {
    question: 'ควรเลือกซิลค์สกรีนหรือ DTG/DTF ดี?',
    answer:
      'ถ้าลายมีไม่กี่สีและสั่งจำนวนมาก ซิลค์สกรีนจะให้สีสดทนทานและต้นทุนต่อตัวต่ำกว่า แต่ถ้าลายมีหลายสี เป็นภาพถ่าย หรือสั่งจำนวนน้อย งานพิมพ์ดิจิทัล DTG/DTF จะเก็บรายละเอียดได้ดีกว่าโดยไม่ต้องทำบล็อกสกรีน ทีมงานช่วยแนะนำให้ตามลายและจำนวนที่ต้องการ',
  },
  {
    question: 'มีบริการออกแบบให้ไหม คิดเงินเพิ่มหรือเปล่า?',
    answer:
      'มีบริการออกแบบฟรี (Design Free) ทีมดีไซน์ช่วยขึ้นแบบ จัดวางลาย และปรับแก้ให้จนพอใจก่อนเริ่มผลิตจริง พร้อมให้คำปรึกษาทุกขั้นตอนโดยไม่มีค่าใช้จ่ายเพิ่ม',
  },
  {
    question: 'รับผลิตเสื้อประเภทไหนบ้าง?',
    answer:
      'รับผลิตเสื้อยืด เสื้อโปโล แจ็คเก็ต เสื้อช็อป รวมถึงกระเป๋าผ้า ครบวงจรตั้งแต่เลือกเนื้อผ้า ตัดเย็บ ไปจนถึงงานสกรีนและงานพิมพ์ทุกเทคนิค',
  },
  {
    question: 'ขอใบเสนอราคาได้อย่างไร?',
    answer:
      'เพียงทักเข้ามาแจ้งแบบเสื้อ จำนวน และลวดลายที่ต้องการ ทีมงานจะช่วยประเมินราคา แนะนำเนื้อผ้าและเทคนิคสกรีน พร้อมส่งใบเสนอราคาและออกแบบให้ดูก่อนตัดสินใจ',
  },
  {
    question: 'ต้องเตรียมไฟล์ลายสกรีนแบบไหน?',
    answer:
      'ไฟล์เวกเตอร์ (AI, EPS, PDF) คมชัดที่สุดเพราะขยายได้ไม่แตก หากเป็นไฟล์ภาพ (PNG/JPG) ควรความละเอียดสูงอย่างน้อย 300 dpi เท่าขนาดที่จะพิมพ์จริง ถ้ายังไม่มีไฟล์พร้อม ทีมออกแบบช่วยจัดทำและเกลาไฟล์ให้ฟรีก่อนผลิต',
  },
  {
    question: 'สกรีนได้กี่สี มีค่าใช้จ่ายต่อสีไหม?',
    answer:
      'งานซิลค์สกรีนคิดต้นทุนตามจำนวนสี (แยกบล็อกต่อสี) ลายไม่กี่สีจึงคุ้มสุด ส่วนงานพิมพ์ดิจิทัล DTG/DTF พิมพ์ได้หลายสีหรือภาพไล่เฉดในครั้งเดียวโดยไม่คิดเพิ่มตามจำนวนสี ทีมงานจะแนะนำเทคนิคที่คุ้มที่สุดตามลายและจำนวนของคุณ',
  },
  {
    question: 'มีบริการทำตัวอย่าง (sample) ก่อนผลิตจริงไหม?',
    answer:
      'มี เราแนะนำให้ดูแบบดิจิทัล (mockup) ทุกงานก่อนเริ่มผลิต และทำตัวอย่างจริงก่อนเดินสายการผลิตได้สำหรับงานจำนวนมาก เพื่อยืนยันเนื้อผ้า สี และตำแหน่งสกรีนให้ตรงใจก่อนผลิตเต็มล็อต',
  },
  {
    question: 'รับงานปักโลโก้ไหม ต่างจากสกรีนอย่างไร?',
    answer:
      'รับงานปักด้วย งานปักให้สัมผัสพรีเมียมและทนทานมาก เหมาะกับโลโก้บนเสื้อโปโล แจ็คเก็ต และยูนิฟอร์มองค์กร ส่วนงานสกรีน/DTF เก็บรายละเอียดลายใหญ่และไล่เฉดสีได้ดีกว่าในต้นทุนที่ถูกกว่า เลือกตามชิ้นงานและภาพลักษณ์ที่ต้องการ',
  },
  {
    question: 'เลือกไซซ์และทรงเสื้อได้แค่ไหน?',
    answer:
      'มีให้เลือกตั้งแต่ไซซ์เด็กถึงผู้ใหญ่ (S–5XL) หลายทรงทั้งคอกลม คอวี โอเวอร์ไซส์ และทรงเข้ารูป สั่งตัดแพทเทิร์นเฉพาะหรือปรับสัดส่วนตามต้องการได้สำหรับงานสั่งผลิต ทีมงานมีเสื้อตัวอย่างให้ลองไซซ์ก่อนสรุปแบบ',
  },
  {
    question: 'ราคาเริ่มต้นเท่าไร คิดราคาอย่างไร?',
    answer:
      'ราคาต่อตัวขึ้นกับชนิดผ้า จำนวน เทคนิคงานพิมพ์ และจำนวนจุด/สีที่สกรีน ยิ่งสั่งจำนวนมากต้นทุนต่อตัวยิ่งลด ทุกงานมีใบเสนอราคาชัดเจนก่อนเริ่มผลิต ไม่มีค่าใช้จ่ายแอบแฝง และออกแบบให้ฟรี',
  },
  {
    question: 'มีโปรโมชันหรือสิทธิพิเศษอะไรบ้าง?',
    answer:
      'ออกแบบฟรีทุกงาน, สกรีนฟรี 1 สี 1 จุด เมื่อสั่งผลิตครบ 100 ตัว และส่งฟรีในเขตกรุงเทพฯ เมื่อมียอดสั่งครบ 20,000 บาท พร้อมให้คำปรึกษาฟรีทุกขั้นตอน',
  },
  {
    question: 'จัดส่งทั่วประเทศไหม คิดค่าส่งอย่างไร?',
    answer:
      'จัดส่งทั่วประเทศผ่านขนส่งมาตรฐาน ค่าส่งคิดตามน้ำหนักและปลายทาง ส่งฟรีในเขตกรุงเทพฯ เมื่อมียอดสั่งครบ 20,000 บาท ทีมงานแจ้งกำหนดส่งที่ชัดเจนพร้อมใบเสนอราคา',
  },
  {
    question: 'ชำระเงินอย่างไร ต้องวางมัดจำไหม?',
    answer:
      'โดยทั่วไปวางมัดจำส่วนหนึ่งก่อนเริ่มผลิต และชำระส่วนที่เหลือเมื่องานเสร็จก่อนจัดส่ง รองรับการโอนผ่านธนาคาร เงื่อนไขการชำระและมัดจำที่แน่นอนจะระบุไว้ในใบเสนอราคาของแต่ละงาน',
  },
];

const faqJsonLd = buildFaqJsonLd(faqItems);

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'รับผลิตเสื้อ สกรีน และงานพิมพ์ผ้าครบวงจร',
  name: 'บริการรับผลิตเสื้อครบวงจร',
  description: SITE.description,
  url: pageUrl,
  provider: {
    '@type': 'LocalBusiness',
    '@id': orgId,
    name: SITE.name,
    legalName: 'บริษัท ธน พลัส 153 จำกัด',
    alternateName: ['ธน พลัส 153', 'Thana Plus 153'],
    image: new URL(logo.src, Astro.site).toString(),
    url: Astro.site?.toString(),
    telephone: SITE.contact.phone,
    email: SITE.contact.email,
    sameAs: [SITE.contact.lineLink],
    address: {
      '@type': 'PostalAddress',
      streetAddress: '503 ถนนสุโขทัย แขวงสวนจิตรลดา',
      addressLocality: 'เขตดุสิต',
      addressRegion: 'กรุงเทพมหานคร',
      postalCode: '10300',
      addressCountry: 'TH',
    },
    priceRange: '$$',
  },
  areaServed: { '@type': 'Country', name: 'Thailand' },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'บริการรับผลิตเสื้อ',
    itemListElement: SERVICES.map((s) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: s.title,
        description: s.description,
      },
    })),
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: Astro.site?.toString() },
    { '@type': 'ListItem', position: 2, name: 'บริการของเรา', item: pageUrl },
  ],
};

const jsonLd = [serviceJsonLd, breadcrumbJsonLd, ...(faqJsonLd ? [faqJsonLd] : [])];

// ข้อมูลขั้นตอนการผลิต (จาก ServiceProcess.astro)
const steps = [
  {
    title: 'ปรึกษา & ขอใบเสนอราคา',
    desc: 'แจ้งแบบเสื้อ จำนวน และลายที่ต้องการ ทีมงานประเมินราคาให้ฟรีรวดเร็ว',
  },
  {
    title: 'ออกแบบ & ขึ้นแบบ',
    desc: 'ทีมดีไซน์ช่วยจัดวางลายและขึ้นม็อคอัพ 3D ให้ดูก่อนตัดสินใจเริ่มผลิตจริง',
  },
  {
    title: 'เลือกผ้า & ยืนยันเสื้อตัวอย่าง',
    desc: 'เลือกเนื้อผ้า สี รูปทรง และตรวจเช็คความสมบูรณ์แบบของเสื้อตัวอย่างจริง',
  },
  {
    title: 'เข้าสู่สายการผลิต & สกรีน',
    desc: 'ตัดเย็บและสกรีนพิมพ์ลวดลายอย่างพิถีพิถันด้วยเครื่องจักรที่ทันสมัย',
  },
  {
    title: 'ตรวจสอบคุณภาพ QC 100%',
    desc: 'ตรวจสอบมาตรฐานทุกจุดตามหลัก QPC ก่อนบรรจุลงกล่องอย่างเรียบร้อย',
  },
  {
    title: 'แพ็คสินค้า & จัดส่งฟรี',
    desc: 'ห่อกันกระแทกอย่างดีและส่งมอบฟรีถึงที่หมายปลายทางทั่วไทย (ตามเงื่อนไข)',
  },
] as const;

// รูปภาพและคีย์สำหรับงานพิมพ์ (จาก ServicePrinting.astro)
const IMAGE_MAP = {
  silk: {
    src: silkScreenImg,
    alt: 'งานซิลค์สกรีน (Silk Screen) ระดับมาตรฐานอุตสาหกรรม',
    badge: 'Silk Screen Printing',
  },
  dtg: {
    src: dftDtgImg,
    alt: 'งานพิมพ์ดิจิทัลระบบ DFT และ DTG ความคมชัดสูง',
    badge: 'Direct-to-Garment / Film',
  },
  sublimation: {
    src: sublimationImg,
    alt: 'งานพิมพ์ซับลิเมชัน (Sublimation) สีสดใสเต็มตัว',
    badge: 'Sublimation Printing',
  },
} as const;



const printingServices = SERVICES.filter((s) => s.printing && s.key && s.key in IMAGE_MAP);
---

<PageLayout
  title="โรงงานผลิตเสื้อผ้า รับผลิตเสื้อครบวงจร สกรีน ออกแบบฟรี"
  description="โรงงานผลิตเสื้อผ้าครบวงจร เสื้อแท้ รับผลิตเสื้อยืด โปโล แจ็คเก็ต ตั้งแต่เลือกผ้า ตัดเย็บ ออกแบบฟรี งานซิลค์สกรีนและ DTG/DTF พร้อมขอใบเสนอราคาฟรี"
  jsonLd={jsonLd}
>
  
  {/* SECTION 1: Redesigned Minimalist Hero */}
  <section class="relative py-20 lg:py-28 select-text">
    <div class="max-w-[1200px] mx-auto text-left">
      <span class="inline-flex items-center justify-center bg-[#FF5A1F] text-white font-black px-4 py-1.5 text-[10px] tracking-wider uppercase mb-6 rounded-none">
        Services & Capabilities
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-gray-900 tracking-tight leading-[1.1] mb-6 uppercase">
        ยกระดับภาพลักษณ์ทีมงาน<br/>
        ด้วยบริการผลิตเสื้อมาตรฐานสากล
      </h1>
      <p class="text-gray-500 text-sm sm:text-base md:text-lg leading-relaxed max-w-2xl font-semibold mb-12">
        บริษัท ธน พลัส 153 จำกัด ผู้ให้บริการรับผลิตเสื้อยืด เสื้อโปโล ยูนิฟอร์ม และเสื้อผ้าสำเร็จรูปสำหรับองค์กรแบบครบวงจร (One-Stop Service) ตั้งแต่วางไอเดีย ออกแบบ ขึ้นแพทเทิร์น จนถึงส่งมอบถึงมือคุณ
      </p>

      {/* Hero Stats Grid */}
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-10 border-t border-gray-150 w-full max-w-4xl">
        <div class="text-left">
          <span class="block text-3xl sm:text-4xl font-black text-[#FF5A1F] leading-none mb-1.5"><span class="counter-number" data-target={works}>0</span>+</span>
          <span class="block text-xs font-bold text-gray-400 uppercase tracking-wider">Product Styles</span>
        </div>
        <div class="text-left">
          <span class="block text-3xl sm:text-4xl font-black text-slate-900 leading-none mb-1.5"><span class="counter-number" data-target="10">0</span>+</span>
          <span class="block text-xs font-bold text-gray-400 uppercase tracking-wider">Years Experience</span>
        </div>
        <div class="text-left">
          <span class="block text-3xl sm:text-4xl font-black text-slate-900 leading-none mb-1.5"><span class="counter-number" data-target="100">0</span>%</span>
          <span class="block text-xs font-bold text-gray-400 uppercase tracking-wider">Custom Tailored</span>
        </div>
        <div class="text-left">
          <span class="block text-3xl sm:text-4xl font-black text-[#FF5A1F] leading-none mb-1.5">QPC</span>
          <span class="block text-xs font-bold text-gray-400 uppercase tracking-wider">Quality Certified</span>
        </div>
      </div>
    </div>
  </section>

  {/* SECTION 2: Core Services Catalogue (Grid Cards) */}
  <section id="services" class="scroll-mt-24 py-16 border-t border-gray-150">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-left mb-16">
        <span class="text-xs font-black tracking-widest text-[#FF5A1F] uppercase mb-3 block">
          Our Main Offerings
        </span>
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 tracking-tight uppercase leading-tight">
          บริการผลิตและขึ้นโครงเสื้อผ้าสำเร็จรูป
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {SERVICES.map((s, idx) => (
          <article class:list={["relative p-8 flex flex-col justify-between items-start min-h-[270px] hover-lift group border border-gray-200/80 bg-white hover:bg-slate-900 hover:text-white hover:border-slate-900 hover:shadow-xl rounded-none select-text reveal-scale", idx === 0 ? "delay-75" : idx === 1 ? "delay-150" : "delay-200"]}>
            
            <div class="flex items-center justify-between w-full mb-6">
              {/* Dashed Border Icon box */}
              <div class="border-2 border-dashed border-gray-300 text-[#FF5A1F] p-2.5 flex items-center justify-center flex-shrink-0 group-hover:border-slate-700">
                {s.icon === 'building-factory-2' && (
