---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Hero from '@/components/home/herosection/Hero.astro';
import Collections from '@/components/home/herosection/Collections.astro';
---

<Layout title="Stripo - Fresh & Stylish">
  <div class="min-h-screen bg-white p-2 sm:p-4 md:p-6 font-sans">
    <div class="max-w-[1400px] mx-auto bg-[#FAFAFA] rounded-[2rem] sm:rounded-[3rem] overflow-hidden relative shadow-sm border border-gray-100">

      <Navbar />

      <main class="px-8 lg:px-12 pt-8 pb-12">
        <Hero />
        <Collections />
      </main>

    </div>
  </div>
</Layout>
