---
import PageLayout from '@/layouts/PageLayout.astro';
import Hero from '@/components/home/Hero.astro';
import Collections from '@/components/home/Collections.astro';
import ScreenServices from '@/components/home/ScreenServices.astro';
import Privileges from '@/components/home/Privileges.astro';
import WhyChooseUs from '@/components/home/WhyChooseUs.astro';
import BlogFeed from '@/components/home/BlogFeed.astro';
import Faq from '@/components/Faq.astro';
import { buildFaqJsonLd, type FaqItem } from '@/lib/faq';

// คำถามที่พบบ่อยของหน้าแรก — แหล่งข้อมูลชุดเดียว ป้อนทั้ง accordion + FAQPage JSON-LD
const faqItems: FaqItem[] = [
  {
    question: 'รับผลิตเสื้ออะไรบ้าง?',
    answer:
      'เรารับผลิตเสื้อยืด เสื้อโปโล แจ็คเก็ต เสื้อช็อป และกระเป๋าผ้า แบบครบวงจรในที่เดียว ตั้งแต่เลือกเนื้อผ้า ตัดเย็บ สกรีน ตรวจสอบคุณภาพ แพ็ค ไปจนถึงจัดส่งถึงมือคุณ',
  },
  {
    question: 'มีบริการช่วยออกแบบให้ไหม?',
    answer:
      'มีบริการช่วยออกแบบฟรี (Design Free) พร้อมทีมงานมืออาชีพให้คำปรึกษาฟรีทุกขั้นตอน ตั้งแต่เลือกแบบเสื้อ เลือกเนื้อผ้า ไปจนถึงเทคนิคการสกรีนที่เหมาะกับงานของคุณ',
  },
  {
    question: 'รองรับงานสกรีนแบบไหนบ้าง?',
    answer:
      'รองรับทั้งงานสกรีนบล็อก (ซิลค์สกรีน) และสกรีนดิจิตอล โดยทีมงานจะแนะนำเทคนิคที่เหมาะกับลวดลายและจำนวนที่สั่งผลิต เพื่อให้ได้งานคุณภาพในราคาที่คุ้มค่า',
  },
  {
    question: 'มีสิทธิพิเศษหรือโปรโมชันอะไรบ้าง?',
    answer:
      'ออกแบบฟรี, สกรีนฟรี 1 สี 1 จุด เมื่อสั่งผลิตครบ 100 ตัว, ส่งฟรีเฉพาะในกรุงเทพฯ เมื่อมียอดสั่งครบ 20,000 บาท และให้คำปรึกษาฟรีทุกขั้นตอน',
  },
  {
    question: 'ทำไมต้องเลือกโรงงานผลิตเสื้อ ธน พลัส 153?',
    answer:
      'เราผลิตด้วยเครื่องจักรและทีมช่างมืออาชีพในทุกขั้นตอน ควบคุมงานตามมาตรฐาน QPC (Quality, Price, Control) ด้วยประสบการณ์กว่า 10 ปี ที่แบรนด์และองค์กรชั้นนำไว้วางใจ',
  },
  {
    question: 'สั่งผลิตเสื้อเริ่มต้นอย่างไร?',
    answer:
      'เพียงทักเข้ามาปรึกษากับทีมงานได้ฟรี แจ้งแบบเสื้อ จำนวน และลวดลายที่ต้องการ ทีมงานจะช่วยประเมินราคา แนะนำเนื้อผ้าและเทคนิคสกรีน พร้อมออกแบบให้ก่อนเริ่มผลิตจริง',
  },
  {
    question: 'รับผลิตเสื้อให้องค์กร ทีม และงานอีเวนต์ไหม?',
    answer:
      'รับผลิตครบทุกกลุ่ม ทั้งยูนิฟอร์มองค์กร เสื้อพนักงาน เสื้อทีมกีฬา เสื้อรุ่น เสื้ออีเวนต์ และของพรีเมียมแจกงาน สั่งได้ตั้งแต่จำนวนไม่มากไปจนถึงล็อตใหญ่ พร้อมคุมสีและแบบให้เหมือนกันทุกตัว',
  },
  {
    question: 'โรงงานอยู่ที่ไหน ติดต่อช่องทางไหน?',
    answer:
      'เราอยู่ที่กรุงเทพมหานคร (เขตดุสิต) ปรึกษาและสั่งผลิตสะดวกสุดทาง LINE @thanaplus หรือโทร 090-201-9121 ทีมงานตอบไว ช่วยประเมินราคาและแนะนำงานให้ฟรี',
  },
  {
    question: 'มือใหม่สั่งจำนวนน้อยเพื่อทดลองตลาดได้ไหม?',
    answer:
      'ได้ งานพิมพ์ดิจิทัล (DTG/DTF) เริ่มผลิตจำนวนน้อยได้ เหมาะกับมือใหม่ที่อยากทดลองตลาดก่อนสั่งล็อตใหญ่ ทีมงานช่วยแนะนำเนื้อผ้าและเทคนิคที่คุ้มที่สุดตามงบและจำนวนที่มี',
  },
  {
    question: 'ทำป้ายแบรนด์ติดเสื้อให้แบรนด์เราได้ไหม?',
    answer:
      'ได้ รองรับงานติดป้ายแบรนด์ทั้งป้ายทอ (woven label) ป้ายไซซ์ และแท็กกระดาษ (hangtag) เพื่อให้เสื้อดูเป็นแบรนด์ของคุณเองเต็มตัว แจ้งรายละเอียดที่ต้องการมาในขั้นขอใบเสนอราคาได้เลย',
  },
  {
    question: 'รับประกันคุณภาพอย่างไร ถ้างานมีปัญหา?',
    answer:
      'เราควบคุมงานตามมาตรฐาน QPC (Quality, Price, Control) ตรวจคุณภาพก่อนแพ็กทุกตัว หากพบงานผิดจากที่ตกลง (เช่น สกรีนเพี้ยน ตัดเย็บไม่ได้มาตรฐาน) ทีมงานรับผิดชอบแก้ไขให้ตามเงื่อนไขที่ระบุในใบเสนอราคา',
  },
  {
    question: 'ใช้เวลาผลิตและจัดส่งนานแค่ไหน?',
    answer:
      'ระยะเวลาขึ้นกับจำนวนและเทคนิคงานพิมพ์ โดยทั่วไปแจ้งกำหนดส่งชัดเจนพร้อมใบเสนอราคา จัดส่งทั่วประเทศ และส่งฟรีในเขตกรุงเทพฯ เมื่อมียอดสั่งครบ 20,000 บาท',
  },
  {
    question: 'รับงานเร่งด่วนไหม?',
    answer:
      'รับพิจารณางานด่วนเป็นกรณีไป ขึ้นกับจำนวน เทคนิค และคิวการผลิตช่วงนั้น แนะนำให้แจ้งกำหนดที่ต้องการใช้งานตั้งแต่ต้น ทีมงานจะช่วยวางแผนและเสนอทางที่ทันเวลาที่สุดให้',
  },
  {
    question: 'เลือกเนื้อผ้าและสีได้หลากหลายแค่ไหน?',
    answer:
      'มีเนื้อผ้าให้เลือกครบ ทั้งคอตตอน 100% คอตตอนคอมแบ็ด TC/TK และผ้ากีฬาระบายอากาศ พร้อมสีให้เลือกหลากหลาย ทีมงานมีตัวอย่างผ้าและสีจริงให้เทียบก่อนตัดสินใจ เพื่อให้ได้งานตรงกับภาพที่ต้องการ',
  },
  {
    question: 'ดูตัวอย่างผลงานและรีวิวลูกค้าได้ที่ไหน?',
    answer:
      'ดูตัวอย่างงานจริงได้ที่หน้าผลงานของเรา ซึ่งรวมงานรับผลิตเสื้อยืด โปโล และงานสกรีนหลากหลายสไตล์ พร้อมรีวิวจากลูกค้าทั้งสตาร์ทอัพ องค์กร และเจ้าของแบรนด์ที่ไว้วางใจให้เราผลิตให้',
  },
];

// FAQPage JSON-LD จากชุดข้อมูลเดียวกับ accordion (กัน schema drift)
const faqJsonLd = buildFaqJsonLd(faqItems);
---

<PageLayout
  title="โรงงานรับผลิตเสื้อครบวงจร สกรีน ตัดเย็บ ออกแบบฟรี"
  description="บริษัท ธน พลัส 153 จำกัด โรงงานรับผลิตเสื้อยืด โปโล แจ็คเก็ต เสื้อช็อป และกระเป๋าผ้า บริการครบจบในที่เดียว พร้อมงานสกรีน ออกแบบฟรี ส่งฟรีในกรุงเทพฯ"
  jsonLd={faqJsonLd ?? undefined}
>
  <Hero />
  <Collections />
  <ScreenServices />
  <Privileges />
  <WhyChooseUs />
  <BlogFeed />
  <Faq
    items={faqItems}
    title="คำถามที่พบบ่อย"
    class="mt-24 lg:mt-32 mb-20 max-w-4xl mx-auto"
  />
</PageLayout>
