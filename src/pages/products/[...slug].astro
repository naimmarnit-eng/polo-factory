---
import PageLayout from '@/layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

import ProductGallery from '@/components/products/ProductGallery.astro';
import PortfolioCard from '@/components/products/PortfolioCard.astro';
import RelatedServices from '@/components/RelatedServices.astro';
import Faq from '@/components/Faq.astro';
import { buildFaqJsonLd } from '@/lib/faq';
import { SITE } from '@/consts';

// SSG: สร้างหน้าทุกสินค้า ณ build time
export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const d = product.data;

// JSON-LD แบบ Product (ดีต่อ SEO/Rich results)
const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: d.title,
  description: d.description,
  image: new URL(d.image.src, Astro.site).toString(),
  brand: {
    '@type': 'Brand',
    name: SITE.name,
  },
  offers: {
    '@type': 'Offer',
    url: new URL(Astro.url.pathname, Astro.site).toString(),
    priceCurrency: 'THB',
    price: d.price,
    priceValidUntil: '2026-12-31',
    availability: d.inStock
      ? 'https://schema.org/InStock'
      : 'https://schema.org/OutOfStock',
    itemCondition: 'https://schema.org/NewCondition',
  },
};

// Breadcrumb JSON-LD
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: Astro.site?.toString() },
    { '@type': 'ListItem', position: 2, name: 'ผลงาน', item: new URL('/products/', Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: d.title, item: new URL(Astro.url.pathname, Astro.site).toString() },
  ],
};

const faqJsonLd = buildFaqJsonLd(d.faq);

// รวมและตัดรูปซ้ำในแกลเลอรี
const allImages = [d.image, ...(d.gallery || [])].filter((value, index, self) => 
  self.findIndex(img => img.src === value.src) === index
);

// ดึงผลงานอื่นๆ ที่เกี่ยวข้องมาแนะนำท้ายหน้า
const allProducts = await getCollection('products');
const relatedProducts = allProducts
  .filter((p) => p.id !== product.id)
  .slice(0, 6);
---

<PageLayout
  title={d.title}
  description={d.description}
  type="product"
  image={d.image.src}
  jsonLd={[productJsonLd, breadcrumbJsonLd, ...(faqJsonLd ? [faqJsonLd] : [])]}
>
  <div class="mx-auto max-w-7xl">
    
    {/* Navigation Breadcrumb & Back button */}
    <nav class="mb-8 flex items-center justify-between text-sm reveal">
      <a href="/products/" class="inline-flex items-center font-bold text-muted-foreground hover:text-primary transition-colors gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="m15 18-6-6 6-6"/></svg>
        กลับหน้ารวมสินค้า
      </a>
      <div class="hidden sm:flex items-center gap-2 text-xs font-semibold text-muted-foreground">
        <a href="/" class="hover:text-foreground">หน้าแรก</a>
        <span>/</span>
        <a href="/products/" class="hover:text-foreground">ผลงาน</a>
        <span>/</span>
        <span class="text-foreground">{d.title}</span>
      </div>
    </nav>

    {/* Main Product Showcase Section */}
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-start mb-16">
      
      {/* Left Column: Interactive Image Gallery (Span 7) */}
      <div class="lg:col-span-7 space-y-4 reveal-skew">
        
        {/* Main image container */}
        <div class="group relative aspect-[4/5] w-full overflow-hidden rounded-2xl bg-secondary/15 shadow-premium border border-gray-150/50 flex items-center justify-center">
          {d.featured && (
            <span class="absolute top-4 left-4 z-10 bg-gradient-to-r from-[#FF5A1F] to-[#FF8A00] text-white text-[10px] font-black tracking-widest uppercase px-3 py-1.5 rounded-full shadow-md">
              Featured Product
            </span>
          )}
          <Image
            id="main-product-image"
            src={d.image}
            alt={d.imageAlt}
            width={1000}
            height={1250}
            class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 select-none"
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300 pointer-events-none" />
        </div>

        {/* Thumbnail Selector Grid */}
        {allImages.length > 1 && (
          <div class="grid grid-cols-4 sm:grid-cols-5 gap-3.5 pt-2">
            {allImages.map((img, index) => (
              <button
                type="button"
                class={`thumb-btn aspect-square w-full rounded-xl overflow-hidden bg-secondary/10 border border-gray-150 cursor-pointer transition-all hover:scale-105 active:scale-95 ${index === 0 ? 'ring-2 ring-[#FF5A1F]' : ''}`}
                data-src={img.src}
                data-alt={`${d.title} - View ${index + 1}`}
              >
                <Image
                  src={img}
                  alt={`${d.title} - Thumb ${index + 1}`}
                  width={150}
                  height={150}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </button>
            ))}
          </div>
        )}
      </div>

      {/* Right Column: Details & Customizer Panel (Span 5) */}
      <div class="lg:col-span-5 space-y-6 sm:space-y-7 reveal-right">
        
        {/* Title, rating, tags */}
        <div class="space-y-3">
          <div class="flex flex-wrap gap-2">
            {d.tags && d.tags.map(tag => (
              <span class="inline-block bg-orange-50 text-[#FF5A1F] border border-orange-100 text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full">
                {tag}
              </span>
            ))}
          </div>
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-black tracking-tight text-gray-900 leading-tight">
            {d.title}
          </h1>
          <div class="flex items-center gap-2">
            <div class="flex text-amber-400 text-base">★★★★★</div>
            <span class="text-xs font-bold text-gray-500">5.0 (รีวิวจากหน่วยงานและแบรนด์)</span>
          </div>
        </div>

        {/* Price & InStock banner */}
        <div class="p-5 rounded-2xl bg-gray-50/80 border border-gray-200/60 shadow-sm space-y-2 hover-lift">
          <div class="flex items-baseline gap-2">
            {d.price > 0 ? (
              <>
                <span class="text-3xl sm:text-4xl font-black text-[#FF5A1F] tracking-tight">
                  ฿{d.price.toLocaleString('th-TH')}
                </span>
                <span class="text-xs font-bold text-gray-400">/ ตัว (ราคาเริ่มต้นสำหรับการสั่งผลิต)</span>
              </>
            ) : (
              <>
                <span class="text-2xl sm:text-3xl font-black text-[#FF5A1F]">สอบถามราคา</span>
                <span class="text-xs font-bold text-gray-400">(ประเมินราคาฟรีอิงจำนวนและเทคนิค)</span>
              </>
            )}
          </div>
          <div class="flex items-center gap-2 text-xs font-bold">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            <span class="text-gray-600">
              {d.inStock ? 'พร้อมดำเนินการจัดคิวสั่งผลิตทันที' : 'กรุณาสอบถามตารางคิวงาน'}
            </span>
          </div>
        </div>

        {/* Description brief */}
        <p class="text-gray-600 leading-relaxed text-sm sm:text-base font-semibold">
          {d.description}
        </p>

        {/* Colors selector mockup */}
        {d.colors && d.colors.length > 0 && (
          <div class="space-y-2.5">
            <span class="block text-xs font-black text-gray-400 uppercase tracking-widest">
              สีผ้ามาตรฐานยอดนิยม (Colors):
            </span>
            <div class="flex flex-wrap gap-2.5" id="color-swatches">
              {d.colors.map((color, idx) => (
                <button
                  type="button"
                  class={`w-8.5 h-8.5 rounded-full border-2 border-white shadow-md cursor-pointer hover:scale-115 active:scale-95 transition-all ${idx === 0 ? 'ring-2 ring-[#FF5A1F]' : 'ring-1 ring-gray-200'}`}
                  style={`background-color: ${color};`}
                  title={`รหัสสีผ้า: ${color}`}
                  data-color={color}
                />
              ))}
            </div>
          </div>
        )}

        {/* Sizes selector mockup */}
        {d.sizes && d.sizes.length > 0 && (
          <div class="space-y-2.5">
            <div class="flex items-center justify-between">
              <span class="text-xs font-black text-gray-400 uppercase tracking-widest">
                ขนาดไซซ์ที่ให้บริการผลิต (Sizes):
              </span>
              <button type="button" id="size-chart-trigger" class="text-xs font-bold text-[#FF5A1F] hover:underline cursor-pointer">
                ดูข้อมูลตารางไซซ์เสื้อ →
              </button>
            </div>
            <div class="flex flex-wrap gap-2.5" id="size-selectors">
              {d.sizes.map((size, idx) => (
                <button
                  type="button"
                  class={`min-w-[48px] h-11 px-3.5 rounded-xl border text-xs font-black cursor-pointer transition-all hover:scale-105 active:scale-95 ${idx === 0 ? 'border-gray-900 bg-gray-950 text-white shadow-sm' : 'border-gray-200 bg-white text-gray-700 hover:border-gray-400'}`}
                  data-size={size}
                >
                  {size}
                </button>
              ))}
            </div>
          </div>
        )}

        {/* Action Button Group */}
        <div class="flex flex-col sm:flex-row gap-3.5 pt-2">
          <a
            href={SITE.contact.lineLink}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 inline-flex items-center justify-center gap-2.5 bg-gradient-to-r from-[#FF5A1F] to-[#FF8A00] hover:from-[#E04E17] hover:to-[#FF5A1F] text-white font-black px-8 py-4 rounded-xl shadow-lg shadow-orange-600/10 hover:shadow-orange-600/25 transition-all duration-300 text-center pulse-glow text-base"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5.5 w-5.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <span>สั่งผลิตเสื้อ / สอบถามทาง LINE</span>
          </a>
          <a
            href={SITE.contact.phoneLink}
            class="inline-flex items-center justify-center gap-2.5 border-2 border-gray-200 hover:border-gray-900 hover:bg-gray-50 text-gray-900 font-bold px-6 py-4 rounded-xl transition-all duration-300 text-center text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>โทรสายด่วน</span>
          </a>
        </div>

        {/* Quality points grid */}
        <div class="pt-6 border-t border-gray-150 grid grid-cols-2 gap-4 text-xs font-semibold text-gray-500">
          <div class="flex items-start gap-2.5">
            <div class="w-5 h-5 rounded-full bg-green-50 text-green-600 flex items-center justify-center shrink-0 mt-0.5 border border-green-100">
              ✓
            </div>
            <span>ออกแบบด้านอก/ปกเสื้อฟรี</span>
          </div>
          <div class="flex items-start gap-2.5">
            <div class="w-5 h-5 rounded-full bg-green-50 text-green-600 flex items-center justify-center shrink-0 mt-0.5 border border-green-100">
              ✓
            </div>
            <span>ปักด้วยคอมพิวเตอร์คมชัด</span>
          </div>
          <div class="flex items-start gap-2.5">
            <div class="w-5 h-5 rounded-full bg-green-50 text-green-600 flex items-center justify-center shrink-0 mt-0.5 border border-green-100">
              ✓
            </div>
            <span>ขึ้นชิ้นงานตัวอย่างจริงก่อนผลิต</span>
          </div>
          <div class="flex items-start gap-2.5">
            <div class="w-5 h-5 rounded-full bg-green-50 text-green-600 flex items-center justify-center shrink-0 mt-0.5 border border-green-100">
              ✓
            </div>
            <span>ส่งฟรีในกรุงเทพฯ (ตามยอดขั้นต่ำ)</span>
          </div>
        </div>

      </div>
    </div>

    {/* Section 2: Tabbed Details (Description, Ordering Process, Size Chart) */}
    <div id="product-tabs-section" class="mb-20 max-w-4xl mx-auto scroll-mt-28 reveal-up delay-150">
      
      {/* Tabs list */}
      <div class="flex border-b border-gray-200 overflow-x-auto no-scrollbar mb-8 font-bold text-sm">
        <button
          type="button"
          data-tab="desc"
          class="tab-btn py-4 px-6 border-b-2 border-[#FF5A1F] text-[#FF5A1F] bg-orange-50/50 rounded-t-xl transition-all duration-300 shrink-0 cursor-pointer"
        >
          รายละเอียดผลิตภัณฑ์
        </button>
        <button
          type="button"
          data-tab="process"
          class="tab-btn py-4 px-6 border-b-2 border-transparent text-gray-500 hover:text-gray-900 rounded-t-xl transition-all duration-300 shrink-0 cursor-pointer"
        >
          ขั้นตอนการสั่งผลิตเสื้อ
        </button>
        <button
          type="button"
          data-tab="sizes"
          class="tab-btn py-4 px-6 border-b-2 border-transparent text-gray-500 hover:text-gray-900 rounded-t-xl transition-all duration-300 shrink-0 cursor-pointer"
        >
          ตารางไซซ์เสื้อมาตรฐาน
        </button>
      </div>

      {/* Tabs panels wrapper */}
      <div class="glass-card rounded-2xl p-6 sm:p-8 shadow-premium border border-gray-200/50">
        
        {/* Panel 1: Description */}
        <div id="tab-panel-desc" class="tab-panel prose prose-neutral max-w-none text-left prose-headings:font-bold prose-a:text-primary text-gray-700">
          <article class="prose prose-neutral max-w-none">
            <Content />
          </article>
        </div>

        {/* Panel 2: Process */}
        <div id="tab-panel-process" class="tab-panel hidden space-y-6">
          <h3 class="text-xl font-bold text-gray-900">สั่งผลิตเสื้อโปโล/ยูนิฟอร์มง่ายใน 5 ขั้นตอน</h3>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5 text-center">
            
            <div class="space-y-2 p-4 bg-white/50 border border-gray-100 rounded-xl">
              <div class="w-10 h-10 rounded-full bg-[#FF5A1F] text-white font-black flex items-center justify-center mx-auto shadow-sm">1</div>
              <h4 class="font-bold text-sm text-gray-900">แจ้งความต้องการ</h4>
              <p class="text-xs text-gray-500">เลือกประเภทเสื้อ แจ้งสี จำนวน และส่งแบบโลโก้ที่ต้องการปัก/สกรีน</p>
            </div>

            <div class="space-y-2 p-4 bg-white/50 border border-gray-100 rounded-xl">
              <div class="w-10 h-10 rounded-full bg-[#FF5A1F] text-white font-black flex items-center justify-center mx-auto shadow-sm">2</div>
              <h4 class="font-bold text-sm text-gray-900">ประเมินราคา</h4>
              <p class="text-xs text-gray-500">ทีมงานทำใบเสนอราคา พร้อมแนะนำผ้าและเทคนิคการปัก/สกรีนให้เหมาะกับงบ</p>
            </div>

            <div class="space-y-2 p-4 bg-white/50 border border-gray-100 rounded-xl">
              <div class="w-10 h-10 rounded-full bg-[#FF5A1F] text-white font-black flex items-center justify-center mx-auto shadow-sm">3</div>
              <h4 class="font-bold text-sm text-gray-900">ขึ้นตัวอย่างงานจริง</h4>
              <p class="text-xs text-gray-500">หลังมัดจำ 50% ทางโรงงานขึ้นงานตัวอย่างเสื้อ/งานปักจริง ให้ลูกค้าตรวจสอบ</p>
            </div>

            <div class="space-y-2 p-4 bg-white/50 border border-gray-100 rounded-xl">
              <div class="w-10 h-10 rounded-full bg-[#FF5A1F] text-white font-black flex items-center justify-center mx-auto shadow-sm">4</div>
              <h4 class="font-bold text-sm text-gray-900">ดำเนินการผลิต</h4>
              <p class="text-xs text-gray-500">ลงคิวช่างทอ ปกเสื้อ และทีมตัดเย็บ-ปัก-สกรีน ควบคุมคุณภาพ QC ทุกตัว</p>
            </div>

            <div class="space-y-2 p-4 bg-white/50 border border-gray-100 rounded-xl">
              <div class="w-10 h-10 rounded-full bg-[#FF5A1F] text-white font-black flex items-center justify-center mx-auto shadow-sm">5</div>
              <h4 class="font-bold text-sm text-gray-900">ตรวจรับและจัดส่ง</h4>
              <p class="text-xs text-gray-500">บรรจุแพ็คเสื้อเรียบร้อย พร้อมจัดส่งด่วนถึงที่หมายทั่วไทย</p>
            </div>

          </div>
        </div>

        {/* Panel 3: Size Chart */}
        <div id="tab-panel-sizes" class="tab-panel hidden space-y-6">
          <h3 class="text-xl font-bold text-gray-900 mb-4">ตารางขนาดมาตรฐานเสื้อโปโลผู้ใหญ่ (Unisex Size Guide)</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm border-collapse">
              <thead>
                <tr class="bg-gray-50 border-b border-gray-200">
                  <th class="py-3 px-4 font-black text-gray-900">ไซซ์ (Size)</th>
                  <th class="py-3 px-4 font-black text-gray-900">รอบอกเสื้อ (Chest Size - นิ้ว)</th>
                  <th class="py-3 px-4 font-black text-gray-900">ความยาวเสื้อ (Length - นิ้ว)</th>
                  <th class="py-3 px-4 font-black text-gray-900">ความเหมาะสมทั่วไป</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 text-gray-700">
                <tr class="hover:bg-gray-50/50 transition-colors">
                  <td class="py-3.5 px-4 font-bold">S</td>
                  <td class="py-3.5 px-4">38"</td>
                  <td class="py-3.5 px-4">26"</td>
                  <td class="py-3.5 px-4">สำหรับสัดส่วนรูปร่างบางหรือผู้หญิงต้องการทรงกะทัดรัด</td>
                </tr>
                <tr class="hover:bg-gray-50/50 transition-colors">
                  <td class="py-3.5 px-4 font-bold">M</td>
                  <td class="py-3.5 px-4">40"</td>
                  <td class="py-3.5 px-4">27"</td>
                  <td class="py-3.5 px-4">ไซซ์มาตรฐานสำหรับรูปร่างมาตรฐาน ชาย/หญิง</td>
                </tr>
                <tr class="hover:bg-gray-50/50 transition-colors">
                  <td class="py-3.5 px-4 font-bold">L</td>
                  <td class="py-3.5 px-4">42"</td>
                  <td class="py-3.5 px-4">28"</td>
                  <td class="py-3.5 px-4">รูปร่างท้วมหรือต้องการใส่แบบหลวมสบายเล็กน้อย</td>
                </tr>
                <tr class="hover:bg-gray-50/50 transition-colors">
                  <td class="py-3.5 px-4 font-bold">XL</td>
                  <td class="py-3.5 px-4">44"</td>
                  <td class="py-3.5 px-4">29"</td>
                  <td class="py-3.5 px-4">สัดส่วนขนาดพิเศษ คล่องตัว</td>
                </tr>
                <tr class="hover:bg-gray-50/50 transition-colors">
                  <td class="py-3.5 px-4 font-bold">XXL</td>
                  <td class="py-3.5 px-4">46"</td>
                  <td class="py-3.5 px-4">30"</td>
                  <td class="py-3.5 px-4">สัดส่วนพลัสไซซ์พิเศษ รองรับทุกรูปทรงพนักงาน</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-muted-foreground font-semibold">
            * สัดส่วนเสื้อจริงอาจคลาดเคลื่อนจากการตัดเย็บประมาณ ±0.5 นิ้ว ตามมาตรฐานเสื้อผ้าสำเร็จรูป / สามารถสั่งทอความยาวปกเสื้อตามแบบที่ระบุได้
          </p>
        </div>

      </div>
    </div>

    {/* Section 3: Interactive Gallery Component (Masonry list with lightbox) */}
    <div class="reveal-up delay-300">
      <div class="border-t border-gray-200 pt-16 mb-6">
        <h2 class="text-2xl sm:text-3xl font-black text-gray-900 text-center tracking-tight">
          มุมมองตัวอย่างงานชิ้นจริงเพิ่มเติม
        </h2>
        <p class="text-center text-sm text-gray-500 font-bold mt-1.5">คลิกที่รูปเพื่อเปิดดูแบบเต็มหน้าจอ (Lightbox)</p>
      </div>
      <ProductGallery images={[d.image, ...(d.gallery || [])]} altPrefix={d.title} />
    </div>

    {/* Section 4: Related Products Carousel Slider */}
    {relatedProducts.length > 0 && (
      <div class="mt-24 border-t border-gray-200 pt-16 reveal-up overflow-hidden">
        <h2 class="text-2xl sm:text-3xl font-black text-gray-900 text-center tracking-tight mb-4">
          ผลงานผลิตเสื้ออื่นๆ ที่คุณอาจสนใจ
        </h2>
        <p class="text-center text-sm text-gray-500 font-bold mb-10">ตัวอย่างงานทอ ตัดเย็บ และงานสกรีนปักจากโรงงานเสื้อโปโล ธน พลัส 153</p>
        
        <div class="relative overflow-hidden w-full py-4">
          <div id="related-products-slider-track" class="flex gap-6 transition-transform duration-500 ease-in-out font-sans">
            {relatedProducts.map((p) => (
              <div class="related-product-slide shrink-0 w-full sm:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)]">
                <PortfolioCard 
                  id={p.id}
                  title={p.data.title}
                  description={p.data.description}
                  image={p.data.image}
                  imageAlt={p.data.imageAlt}
                  tags={p.data.tags}
                />
              </div>
            ))}
          </div>

          <!-- Slider Controls -->
          <div class="flex items-center justify-center gap-4 mt-12" id="related-slider-controls">
            <button type="button" id="related-prev-slide" class="w-10 h-10 rounded-full border border-gray-200 bg-white hover:border-[#FF5A1F] hover:text-[#FF5A1F] text-gray-700 flex items-center justify-center cursor-pointer transition-all shadow-sm disabled:opacity-30 disabled:cursor-not-allowed">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            
            <div class="flex items-center gap-2" id="related-slider-dots">
              {/* Dots will be generated dynamically */}
            </div>

            <button type="button" id="related-next-slide" class="w-10 h-10 rounded-full border border-gray-200 bg-white hover:border-[#FF5A1F] hover:text-[#FF5A1F] text-gray-700 flex items-center justify-center cursor-pointer transition-all shadow-sm disabled:opacity-30 disabled:cursor-not-allowed">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          </div>
        </div>
      </div>
    )}

    {/* FAQ Accordion Section */}
    {d.faq && d.faq.length > 0 && (
      <div class="max-w-3xl mx-auto mt-24 reveal-up delay-200">
        <Faq items={d.faq} />
      </div>
    )}

    {/* Internal link services */}
    <div class="reveal-up delay-300">
      <RelatedServices class="max-w-3xl mx-auto mt-20" />
    </div>

  </div>
</PageLayout>

<script>
  // Tab controller
  function setupTabs() {
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Remove active states from all tabs
        tabBtns.forEach(b => {
          b.classList.remove('border-[#FF5A1F]', 'text-[#FF5A1F]', 'bg-orange-50/50');
          b.classList.add('border-transparent', 'text-gray-500');
        });
        // Hide all panels
        tabPanels.forEach(p => p.classList.add('hidden'));

        // Add active states to current tab
        btn.classList.add('border-[#FF5A1F]', 'text-[#FF5A1F]', 'bg-orange-50/50');
        btn.classList.remove('border-transparent', 'text-gray-500');

        // Show target panel
        const targetId = btn.getAttribute('data-tab');
        const targetPanel = document.getElementById(`tab-panel-${targetId}`);
        if (targetPanel) {
          targetPanel.classList.remove('hidden');
        }
      });
    });
  }

  // Gallery image swap, sizes button selector, color swatch selections
  function setupProductInteractions() {
    // Thumbnail swap
    const thumbnails = document.querySelectorAll('.thumb-btn');
    const mainImg = document.getElementById('main-product-image') as HTMLImageElement;

    thumbnails.forEach(thumb => {
      thumb.addEventListener('click', () => {
        thumbnails.forEach(t => t.classList.remove('ring-2', 'ring-[#FF5A1F]'));
        thumb.classList.add('ring-2', 'ring-[#FF5A1F]');

        const newSrc = thumb.getAttribute('data-src');
        const newAlt = thumb.getAttribute('data-alt');
        if (mainImg && newSrc && newAlt) {
          mainImg.src = newSrc;
          mainImg.alt = newAlt;
        }
      });
    });

    // Size selection simulation
    const sizeBtns = document.querySelectorAll('#size-selectors button');
    sizeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        sizeBtns.forEach(b => {
          b.classList.remove('border-gray-900', 'bg-gray-950', 'text-white', 'shadow-sm');
          b.classList.add('border-gray-200', 'bg-white', 'text-gray-700', 'hover:border-gray-400');
        });
        btn.classList.remove('border-gray-200', 'bg-white', 'text-gray-700', 'hover:border-gray-400');
        btn.classList.add('border-gray-900', 'bg-gray-950', 'text-white', 'shadow-sm');
      });
    });

    // Color selection simulation
    const colorSwatches = document.querySelectorAll('#color-swatches button');
    colorSwatches.forEach(swatch => {
      swatch.addEventListener('click', () => {
        colorSwatches.forEach(s => {
          s.classList.remove('ring-2', 'ring-[#FF5A1F]');
          s.classList.add('ring-1', 'ring-gray-200');
        });
        swatch.classList.add('ring-2', 'ring-[#FF5A1F]');
        swatch.classList.remove('ring-1', 'ring-gray-200');
      });
    });

    // Scroll to size tab when clicking link
    const sizeChartTrigger = document.getElementById('size-chart-trigger');
    const tabSizeBtn = document.querySelector('[data-tab="sizes"]') as HTMLButtonElement;
    if (sizeChartTrigger && tabSizeBtn) {
      sizeChartTrigger.addEventListener('click', () => {
        tabSizeBtn.click();
        const tabContainer = document.getElementById('product-tabs-section');
        if (tabContainer) {
          tabContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    }
  }

  function setupRelatedProductsSlider() {
    const track = document.getElementById('related-products-slider-track') as HTMLElement;
    const slides = document.querySelectorAll('.related-product-slide') as NodeListOf<HTMLElement>;
    const prevBtn = document.getElementById('related-prev-slide');
    const nextBtn = document.getElementById('related-next-slide');
    const dotsContainer = document.getElementById('related-slider-dots');

    if (!track || slides.length === 0) return;

    let currentIndex = 0;
    let autoPlayInterval: number | null = null;

    function getItemsPerPage() {
      if (window.innerWidth >= 1024) return 3;
      if (window.innerWidth >= 640) return 2;
      return 1;
    }

    function getMaxIndex() {
      return Math.max(0, slides.length - getItemsPerPage());
    }

    function updateSlider() {
      const maxIndex = getMaxIndex();
      if (currentIndex > maxIndex) {
        currentIndex = maxIndex;
      }
      if (currentIndex < 0) {
        currentIndex = 0;
      }

      const slideWidth = slides[0].getBoundingClientRect().width;
      const gap = 24; // gap-6
      const offset = -currentIndex * (slideWidth + gap);
      track.style.transform = `translateX(${offset}px)`;

      updateDots();

      if (prevBtn) {
        const prevHtmlBtn = prevBtn as HTMLButtonElement;
        prevHtmlBtn.disabled = currentIndex === 0;
        prevHtmlBtn.style.opacity = currentIndex === 0 ? '0.35' : '1';
      }
      if (nextBtn) {
        const nextHtmlBtn = nextBtn as HTMLButtonElement;
        nextHtmlBtn.disabled = currentIndex === maxIndex;
        nextHtmlBtn.style.opacity = currentIndex === maxIndex ? '0.35' : '1';
      }
    }

    function updateDots() {
      if (!dotsContainer) return;
      dotsContainer.innerHTML = '';
      const maxIndex = getMaxIndex();
      if (maxIndex <= 0) return;

      for (let i = 0; i <= maxIndex; i++) {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = `w-2 h-2 rounded-full transition-all cursor-pointer ${
          i === currentIndex ? 'bg-[#FF5A1F] w-4' : 'bg-gray-300 hover:bg-gray-400'
        }`;
        dot.setAttribute('aria-label', `Slide to product ${i + 1}`);
        dot.addEventListener('click', () => {
          currentIndex = i;
          updateSlider();
          resetAutoPlay();
        });
        dotsContainer.appendChild(dot);
      }
    }

    function slideNext() {
      const maxIndex = getMaxIndex();
      if (currentIndex < maxIndex) {
        currentIndex++;
      } else {
        currentIndex = 0;
      }
      updateSlider();
    }

    function slidePrev() {
      const maxIndex = getMaxIndex();
      if (currentIndex > 0) {
        currentIndex--;
      } else {
        currentIndex = maxIndex;
      }
      updateSlider();
    }

    function startAutoPlay() {
      stopAutoPlay();
      autoPlayInterval = window.setInterval(slideNext, 4500);
    }

    function stopAutoPlay() {
      if (autoPlayInterval) {
        clearInterval(autoPlayInterval);
        autoPlayInterval = null;
      }
    }

    function resetAutoPlay() {
      startAutoPlay();
    }

    prevBtn?.addEventListener('click', () => {
      slidePrev();
      resetAutoPlay();
    });

    nextBtn?.addEventListener('click', () => {
      slideNext();
      resetAutoPlay();
    });

    let startX = 0;
    track.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      stopAutoPlay();
    }, { passive: true });

    track.addEventListener('touchend', (e) => {
      const diffX = startX - e.changedTouches[0].clientX;
      if (Math.abs(diffX) > 50) {
        if (diffX > 0) {
          slideNext();
        } else {
          slidePrev();
        }
      }
      startAutoPlay();
    }, { passive: true });

    window.addEventListener('resize', () => {
      updateSlider();
    });

    updateSlider();
    startAutoPlay();
  }

  // Astro page transitions initialization
  document.addEventListener('astro:page-load', () => {
    setupTabs();
    setupProductInteractions();
    setupRelatedProductsSlider();
  });

  // Fallback for non-transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setupTabs();
      setupProductInteractions();
      setupRelatedProductsSlider();
    });
  } else {
    setupTabs();
    setupProductInteractions();
    setupRelatedProductsSlider();
  }
</script>

<style>
  /* Hide scrollbar on tabs for clean mobile scroll */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
