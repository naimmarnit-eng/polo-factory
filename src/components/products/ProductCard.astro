---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { Card, CardContent } from '@/components/starwind/card';
import { Badge } from '@/components/starwind/badge';

interface Props {
  id: string;
  title: string;
  price: number;
  image: ImageMetadata;
  imageAlt: string;
  inStock: boolean;
  colors?: string[];
}

const { id, title, price, image, imageAlt, inStock, colors = [] } = Astro.props;
---

<a href={`/products/${id}`} class="group block h-full">
  <Card class="overflow-hidden transition-all duration-300 hover:shadow-lg h-full flex flex-col border-none bg-secondary/20">
    <div class="relative overflow-hidden aspect-[4/5]">
      <Image
        src={image}
        alt={imageAlt}
        width={600}
        height={750}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
      {!inStock && (
        <div class="absolute top-4 left-4">
          <Badge variant="error" class="px-3 py-1 text-sm font-medium shadow-md">
            Out of Stock
          </Badge>
        </div>
      )}
      {colors.length > 0 && (
        <div class="absolute bottom-4 left-4 flex gap-1.5">
          {colors.slice(0, 4).map((color) => (
            <div 
              class="w-4 h-4 rounded-full border border-white shadow-sm"
              style={`background-color: ${color.toLowerCase()};`}
              title={color}
            />
          ))}
          {colors.length > 4 && (
             <div class="w-4 h-4 rounded-full bg-background flex items-center justify-center text-[10px] font-medium border border-border shadow-sm">
               +
             </div>
          )}
        </div>
      )}
    </div>
    <CardContent class="p-6 flex-grow flex flex-col justify-between gap-4">
      <div>
        <h3 class="font-medium text-lg leading-tight group-hover:text-primary transition-colors line-clamp-2">
          {title}
        </h3>
      </div>
      <div class="font-semibold text-lg flex items-center justify-between">
        <span>฿{price.toLocaleString('th-TH')}</span>
        <span class="text-sm font-normal text-muted-foreground opacity-0 group-hover:opacity-100 transition-opacity translate-x-2 group-hover:translate-x-0 duration-300">
          ดูรายละเอียด →
        </span>
      </div>
    </CardContent>
  </Card>
</a>
