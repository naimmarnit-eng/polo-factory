---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  id: string;
  title: string;
  description?: string;
  image: ImageMetadata;
  imageAlt: string;
  tags?: string[];
}

const { id, title, description, image, imageAlt, tags = [] } = Astro.props;
---

<a href={`/products/${id}`} data-tags={tags.join(' ')} class="portfolio-card group block mb-4 sm:mb-6 break-inside-avoid relative overflow-hidden rounded-2xl bg-secondary/10 reveal-scale hover-lift">
  <Image
    src={image}
    alt={imageAlt}
    class="w-full aspect-[4/5] object-cover transition-transform duration-750 ease-out group-hover:scale-105"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-5 md:p-6 text-white">
    <h3 class="font-bold text-lg md:text-xl mb-1 translate-y-3 group-hover:translate-y-0 transition-transform duration-350 ease-out">{title}</h3>
    {description && (
      <p class="text-xs opacity-90 line-clamp-2 translate-y-3 group-hover:translate-y-0 transition-transform duration-350 delay-75 ease-out">{description}</p>
    )}
  </div>
</a>
