---
// Navbar — แถบนำทางส่วนหัวของหน้าเว็บ (Overhauled to IndustryFlow dual-row style)
import { Image } from 'astro:assets';
import logo from '@/assets/logo.png';
import { SITE } from '@/consts';

const serviceMenu = [
  { label: 'บริการทั้งหมด', desc: 'รับผลิตเสื้อโปโลครบวงจร', href: '/services/#services' },
  { label: 'งานสกรีน & งานพิมพ์', desc: 'ซิลค์สกรีน · DTG/DTF · Sublimation', href: '/services/#screen' },
  { label: 'ขั้นตอนการสั่งผลิต', desc: 'สั่งผลิตง่ายใน 6 ขั้นตอน', href: '/services/#process' },
  { label: 'คำถามที่พบบ่อย', desc: 'ราคา · ขั้นต่ำ · ระยะเวลา', href: '/services/#faq-heading' },
] as const;
---

{/* Top Mini bar - Mockup Style */}
<div class="bg-[#1a1a1a] text-gray-300 text-[11px] font-bold hidden md:block border-b border-gray-800 tracking-wider w-full">
  <div class="max-w-[1400px] mx-auto px-8 py-2.5 flex justify-between items-center">
    <div class="flex items-center gap-6">
      <a href="tel:090-201-9121" class="flex items-center gap-1.5 hover:text-[#FF5A1F] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>090-201-9121</span>
      </a>
      <a href="mailto:thanaplus153@gmail.com" class="flex items-center gap-1.5 hover:text-[#FF5A1F] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <span>thanaplus153@gmail.com</span>
      </a>
    </div>
    <div class="flex items-center gap-4.5">
      <a href={SITE.contact.lineLink} target="_blank" rel="noopener noreferrer" class="hover:text-[#FF5A1F] transition-colors">LINE: @thanaplus</a>
    </div>
  </div>
</div>

{/* Main Header Row */}
<header class="sticky top-4 z-50 mx-4 sm:mx-6 lg:mx-8 mb-[-5.25rem] backdrop-blur-md bg-white/95 rounded-2xl border border-gray-200/80 shadow-md transition-all duration-300 w-auto">
  <div class="max-w-[1400px] mx-auto flex items-center justify-between px-6 py-3.5 lg:px-10 w-full">
    
    {/* Logo block */}
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="p-1.5 bg-gray-50 rounded-xl group-hover:scale-105 transition-transform duration-300 border border-gray-200/50">
        <Image src={logo} alt="โรงงานเสื้อโปโล ธน พลัส 153" width={28} height={28} class="w-7 h-7 object-contain" />
      </div>
      <span class="text-xl font-black tracking-tight text-gray-900 group-hover:opacity-80 transition-opacity">
        โรงงานเสื้อโปโล<span class="text-[#FF5A1F]">.com</span>
      </span>
    </a>

    {/* Desktop Navigation */}
    <nav class="hidden md:flex items-center gap-8 text-sm font-semibold text-gray-700">
      
      {/* Services Dropdown */}
      <div class="relative group">
        <a
          href="/services/"
          class="flex items-center gap-1 py-1 hover:text-[#FF5A1F] transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-[#FF5A1F] hover:after:w-full after:transition-all after:duration-300"
          aria-haspopup="true"
        >
          Services
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:rotate-180" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </a>

        <div class="invisible absolute left-0 top-full z-50 pt-2 opacity-0 translate-y-1 transition-all duration-200 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0">
          <ul class="w-72 rounded-2xl border border-gray-150 bg-white p-2.5 shadow-xl shadow-gray-200/50">
            {serviceMenu.map((m) => (
              <li>
                <a href={m.href} class="block rounded-xl px-4 py-2.5 hover:bg-gray-50/80 hover:text-[#FF5A1F] transition-colors">
                  <span class="block font-bold text-gray-900 hover:text-[#FF5A1F] transition-colors text-sm">{m.label}</span>
                  <span class="block text-xs text-gray-400 font-medium mt-0.5">{m.desc}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <a href="/blog/" class="py-1 hover:text-[#FF5A1F] transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-[#FF5A1F] hover:after:w-full after:transition-all after:duration-300">Blog</a>
      <a href="/products/" class="py-1 hover:text-[#FF5A1F] transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-[#FF5A1F] hover:after:w-full after:transition-all after:duration-300">Products</a>
      
      {/* Orange Mockup Button */}
      <a
        href="/services/#contact"
        class="inline-flex items-center gap-2 bg-[#FF5A1F] hover:bg-[#E04E17] text-white text-xs font-black px-5 py-2.5 rounded-xl shadow-sm hover:shadow transition-all duration-300 group/contact"
      >
        <span>ขอใบเสนอราคาฟรี</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover/contact:translate-x-0.5 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </nav>

    {/* Mobile Menu */}
    <div class="md:hidden relative">
      <details class="group">
        <summary class="flex items-center justify-center p-2.5 rounded-xl border border-gray-200 bg-white hover:bg-gray-50 list-none [&::-webkit-details-marker]:hidden cursor-pointer select-none focus:outline-none focus:ring-2 focus:ring-gray-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="block group-open:hidden text-gray-700"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="hidden group-open:block text-gray-700"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
        </summary>
        <div class="absolute right-0 top-full mt-2.5 z-50 w-60 rounded-2xl border border-gray-100 bg-white p-3 shadow-xl shadow-gray-200/60 flex flex-col gap-1">
          <a href="/services/" class="block rounded-xl px-4 py-2.5 text-sm font-bold text-gray-900 hover:bg-gray-50 hover:text-[#FF5A1F] transition-colors">Services</a>
          <div class="pl-4 flex flex-col border-l border-gray-100 my-0.5">
            {serviceMenu.map((m) => (
              <a href={m.href} class="block py-1.5 px-3 text-xs font-semibold text-gray-500 hover:text-[#FF5A1F] hover:bg-gray-50 rounded-lg transition-colors">{m.label}</a>
            ))}
          </div>
          <a href="/blog/" class="block rounded-xl px-4 py-2.5 text-sm font-bold text-gray-900 hover:bg-gray-50 hover:text-[#FF5A1F] transition-colors">Blog</a>
          <a href="/products/" class="block rounded-xl px-4 py-2.5 text-sm font-bold text-gray-900 hover:bg-gray-50 hover:text-[#FF5A1F] transition-colors">Products</a>
          <hr class="border-gray-100 my-1"/>
          <a href="/services/#contact" class="flex items-center justify-between rounded-xl bg-orange-50 px-4 py-3 text-sm font-bold text-[#FF5A1F] hover:bg-orange-100 transition-colors">
            <span>ขอใบเสนอราคาฟรี</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </details>
    </div>

  </div>
</header>
