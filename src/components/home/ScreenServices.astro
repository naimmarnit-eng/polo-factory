---
import { Image } from 'astro:assets';
import silkScreen from '@/assets/home/ScreenServices/Silk Screen.png';
---

{/* Screen Printing & Customization Section - Redesigned to Widescreen Stats Banner */}
<section id="screen" class="scroll-mt-24 mt-24 relative z-20">
  
  <div class="relative w-full overflow-hidden bg-slate-950 min-h-[500px] flex items-center p-8 md:p-12 lg:p-16 shadow-2xl">
    {/* Absolute background image with dark overlay filter */}
    <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-950/85 to-slate-950/70 z-10 pointer-events-none"></div>
    <Image
      src={silkScreen}
      alt="บริการงานปักและสกรีนเสื้อโปโล"
      widths={[400, 800, 1200]}
      sizes="100vw"
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover opacity-30 z-0 select-none pointer-events-none"
    />

    <div class="relative z-20 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        
        {/* Left Column: Text & CTA Button */}
        <div class="lg:col-span-5 text-left flex flex-col items-start reveal-left">
          <span class="text-xs font-black tracking-widest text-[#FF5A1F] uppercase mb-4 block">
            Let's Be Great Together
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-white mb-6 leading-tight uppercase">
            บริการงานปัก<br/>
            และสกรีนเสื้อโปโล
          </h2>
          <p class="text-gray-300 text-sm sm:text-base leading-relaxed mb-8 max-w-xl font-semibold">
            เพิ่มความพรีเมียมและอัตลักษณ์ให้กับเสื้อโปโลพนักงานด้วยเทคโนโลยีงานตกแต่งเนื้อผ้าที่หลากหลายและเครื่องจักรระบบคอมพิวเตอร์ที่แม่นยำสูง
          </p>
          <a
            href="/services/#screen"
            class="inline-flex items-center justify-center bg-[#FF5A1F] hover:bg-[#E04E17] text-white font-black px-8 py-3.5 transition-all duration-300 text-xs tracking-wider uppercase rounded-none"
          >
            Discover More
          </a>
        </div>

        {/* Right Column: 2x2 Grid of Clickable Technique Cards */}
        <div class="lg:col-span-7 reveal-right delay-200">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
            
            {/* Technique 1 */}
            <a href="/services/#screen" class="flex items-center gap-4.5 p-4 rounded-xl border border-white/5 bg-slate-900/20 hover:bg-slate-900/50 hover:border-[#FF5A1F]/30 transition-all duration-300 group">
              <div class="flex-shrink-0 w-14 h-14 rounded-full border-3 border-[#FF5A1F] flex items-center justify-center text-white font-black text-lg bg-black/45 group-hover:scale-105 transition-transform">
                01
              </div>
              <div class="text-left">
                <h4 class="text-white font-black text-sm uppercase group-hover:text-[#FF5A1F] transition-colors">ซิลค์สกรีน (Silk Screen)</h4>
                <p class="text-gray-400 text-xs mt-1 font-semibold leading-relaxed">สีกึ่งยางเกรดพรีเมียม คุ้มค่าที่สุดเมื่อสั่งผลิตจำนวนมาก</p>
              </div>
            </a>

            {/* Technique 2 */}
            <a href="/services/#screen" class="flex items-center gap-4.5 p-4 rounded-xl border border-white/5 bg-slate-900/20 hover:bg-slate-900/50 hover:border-[#FF5A1F]/30 transition-all duration-300 group">
              <div class="flex-shrink-0 w-14 h-14 rounded-full border-3 border-[#FF5A1F] flex items-center justify-center text-white font-black text-lg bg-black/45 group-hover:scale-105 transition-transform">
                02
              </div>
              <div class="text-left">
                <h4 class="text-white font-black text-sm uppercase group-hover:text-[#FF5A1F] transition-colors">พิมพ์ดิจิทัล (DFT / DTG)</h4>
                <p class="text-gray-400 text-xs mt-1 font-semibold leading-relaxed">พิมพ์ไม่จำกัดสี คมชัดสูง ไม่ต้องทำบล็อก เหมาะกับลายซับซ้อน</p>
              </div>
            </a>

            {/* Technique 3 */}
            <a href="/services/#screen" class="flex items-center gap-4.5 p-4 rounded-xl border border-white/5 bg-slate-900/20 hover:bg-slate-900/50 hover:border-[#FF5A1F]/30 transition-all duration-300 group">
              <div class="flex-shrink-0 w-14 h-14 rounded-full border-3 border-[#FF5A1F] flex items-center justify-center text-white font-black text-lg bg-black/45 group-hover:scale-105 transition-transform">
                03
              </div>
              <div class="text-left">
                <h4 class="text-white font-black text-sm uppercase group-hover:text-[#FF5A1F] transition-colors">พิมพ์ซับลิเมชัน</h4>
                <p class="text-gray-400 text-xs mt-1 font-semibold leading-relaxed">สีฝังตรงในเนื้อผ้ากีฬา ระบายอากาศ 100% สวมใส่สบาย</p>
              </div>
            </a>

            {/* Technique 4 */}
            <a href="/services/#screen" class="flex items-center gap-4.5 p-4 rounded-xl border border-white/5 bg-slate-900/20 hover:bg-slate-900/50 hover:border-[#FF5A1F]/30 transition-all duration-300 group">
              <div class="flex-shrink-0 w-14 h-14 rounded-full border-3 border-[#FF5A1F] flex items-center justify-center text-white font-black text-lg bg-black/45 group-hover:scale-105 transition-transform">
                04
              </div>
              <div class="text-left">
                <h4 class="text-white font-black text-sm uppercase group-hover:text-[#FF5A1F] transition-colors">งานปักคอมพิวเตอร์</h4>
                <p class="text-gray-400 text-xs mt-1 font-semibold leading-relaxed">ปักไหมพรีเมียมคมชัดสูง เพิ่มมิติและความน่าเชื่อถือให้เสื้อ</p>
              </div>
            </a>

          </div>
        </div>

      </div>
    </div>
  </div>

</section>
