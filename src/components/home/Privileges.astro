---
const items = [
  {
    num: "01",
    iconName: "drafting",
    title: 'Design Free',
    desc: 'บริการช่วยออกแบบโครงร่างปกเสื้อ ขลิบปก และเลือกคู่สีก่อนการผลิตจริงเพื่อความถูกต้อง 100%'
  },
  {
    num: "02",
    iconName: "palette",
    title: 'Screen & Embroidery Free',
    desc: 'ปักหรือสกรีนตราสัญลักษณ์โลโก้ขนาดปกติ ฟรีจำนวน 1 จุด เมื่อมียอดสั่งผลิตตามเกณฑ์ของโรงงาน'
  },
  {
    num: "03",
    iconName: "truck",
    title: 'Shipping Free',
    desc: 'จัดส่งเสื้อยืดและเสื้อโปโลพนักงาน ฟรีในเขตกรุงเทพมหานครและปริมณฑลโดยรถขนส่งของโรงงาน'
  },
  {
    num: "04",
    iconName: "message",
    title: 'Consult Free',
    desc: 'พร้อมส่งผู้เชี่ยวชาญให้คำแนะนำเกี่ยวกับเกรดเนื้อผ้าทอ และนำตัวอย่างแบบเสื้อจริงเข้าพบเพื่อเสนอแนะ'
  },
  {
    num: "05",
    iconName: "box",
    title: 'Sample Free',
    desc: 'จัดทำตัวอย่างเสื้อจริงให้ตรวจสอบดีไซน์และเนื้อผ้าทอก่อนเริ่มการผลิตล็อตใหญ่ (เมื่อสั่งตามเกณฑ์)'
  },
  {
    num: "06",
    iconName: "shield",
    title: 'QC 100% Free',
    desc: 'บริการตรวจเช็คสเปคขนาดเสื้อ ความเรียบร้อยของเส้นด้าย และแพ็คบรรจุถุงเดี่ยวให้ฟรีทุกตัว'
  }
];
---

{/* Privileges Section - Overhauled to Grid Spec Cards */}
<section class="mt-24 lg:mt-32 relative z-20 py-24 border-t border-b border-gray-150/60 bg-gray-50/20">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
    
    {/* Section Header - Two Columns */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 mb-16 text-left items-start reveal-up">
      <div class="lg:col-span-7">
        <span class="text-xs font-black tracking-widest text-[#FF5A1F] uppercase mb-4 block">
          Factory Privileges
        </span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tight leading-[1.15] text-gray-900 uppercase">
          สิทธิพิเศษและบริการเสริมฟรี <br/>
          <span class="text-[#FF5A1F]">สำหรับคำสั่งสั่งผลิตยูนิฟอร์ม</span>
        </h2>
      </div>
      <div class="lg:col-span-5 lg:pt-8">
        <p class="text-gray-500 text-sm md:text-base font-semibold leading-relaxed">
          เรายินดีอำนวยความสะดวกในกระบวนการทำงานให้กับฝ่ายจัดซื้อและผู้ริเริ่มสร้างแบรนด์ผ้า ด้วยสิทธิประโยชน์พิเศษที่รวมอยู่ในราคาสั่งผลิตตั้งแต่ต้น
        </p>
      </div>
    </div>

    {/* Grid of 6 Cards (2x3 on Desktop) */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 pt-6 reveal-up delay-200">
      {items.map((item, index) => {
        return (
          <div class="relative p-8 flex flex-col justify-between items-start min-h-[250px] hover-lift group border rounded-none bg-white text-gray-900 border-gray-200/80 hover:bg-slate-900 hover:text-white hover:border-slate-900 hover:shadow-xl">
            
            {/* Top Row: Icon inside dashed box (Left) and Diagonal Arrow button (Right) */}
            <div class="flex items-center justify-between w-full mb-8">
              <div class="border-2 border-dashed p-2.5 flex items-center justify-center flex-shrink-0 border-gray-300 text-gray-600 group-hover:border-slate-700 group-hover:text-white">
                {item.iconName === 'drafting' && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                )}
                {item.iconName === 'palette' && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 5-10.9l-4.7-9a1 1 0 0 0-1.6 0l-4.7 9A7 7 0 0 0 12 22z"/></svg>
                )}
                {item.iconName === 'truck' && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2" ry="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                )}
                {item.iconName === 'message' && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                )}
                {item.iconName === 'box' && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                )}
                {item.iconName === 'shield' && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
                )}
              </div>
              
              {/* Top Right arrow icon button matching theme color */}
              <div class="w-9 h-9 flex items-center justify-center transition-all duration-300 bg-gray-150 text-gray-700 group-hover:bg-[#FF5A1F] group-hover:text-white">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </div>
            </div>

            {/* Bottom Row: Text content */}
            <div class="w-full text-left mt-auto">
              <h3 class="text-lg font-black tracking-tight mb-2 uppercase text-gray-900 group-hover:text-white">
                {item.title}
              </h3>
              <p class="text-xs leading-relaxed font-semibold text-gray-500 group-hover:text-slate-400">
                {item.desc}
              </p>
            </div>
            
          </div>
        );
      })}
    </div>

  </div>
</section>
