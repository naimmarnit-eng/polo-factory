---
// Blog Feed (หน้าแรก) — ดึง 3 บทความล่าสุดจริงจาก collection, ซ่อนเองถ้าไม่มีบทความ
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---
{posts.length > 0 && (
<section class="mt-32 mb-20 relative z-20 bg-[#0A1128]/90 text-white p-8 sm:p-12 lg:p-16 border border-slate-800/40 shadow-xl select-text reveal-up">
  <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
    <div>
      <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight">ความรู้เรื่องผ้าและงานสกรีน</h2>
      <p class="text-slate-400 mt-4 text-sm sm:text-base font-semibold">จาก Thanaplus Academy อัปเดตเทรนด์และความรู้ใหม่ๆ ทุกสัปดาห์</p>
    </div>
    <a href="/blog" class="text-white font-semibold underline decoration-2 decoration-slate-700 underline-offset-4 hover:decoration-[#FF5A1F] hover:text-[#FF5A1F] transition-colors shrink-0">ดูบทความทั้งหมด</a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {posts.map((post) => {
      const d = post.data;
      return (
        <a href={`/blog/${post.id}`} class="group block">
          <div class="rounded-none overflow-hidden mb-6 aspect-[4/3] bg-slate-900">
            {d.cover && (
              <Image
                src={d.cover}
                alt={d.coverAlt || d.title}
                widths={[400, 600, 800]}
                sizes="(max-width: 768px) 100vw, 33vw"
                loading="lazy"
                class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
              />
            )}
          </div>
          <div class="flex items-center gap-3 text-sm text-slate-400 mb-3">
            <span class="bg-slate-800/80 px-3 py-1 rounded-none text-slate-200 font-medium text-xs">{d.category}</span>
            <span>{d.publishedAt.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          </div>
          <h3 class="text-xl font-bold text-white mb-2 group-hover:text-[#FF5A1F] transition-colors duration-300 line-clamp-2">{d.title}</h3>
        </a>
      );
    })}
  </div>
</section>
)}
