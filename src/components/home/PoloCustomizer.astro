  /* Pulsing Animation for order button */
  .pulse-glow {
    animation: pulse-glow-btn 2.5s infinite;
  }
  @keyframes pulse-glow-btn {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(6, 199, 85, 0.4);
    }
    50% {
      box-shadow: 0 0 20px 6px rgba(6, 199, 85, 0.2);
    }
  }
</style>
