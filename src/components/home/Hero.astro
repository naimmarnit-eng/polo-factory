---
import { Image } from 'astro:assets';
import heroImg from '@/assets/home/hero-img.png';
---

{/* Hero Container */}
<div class="relative w-full mb-16">
  
  {/* Cinematic Widescreen Banner Block */}
  <div class="relative w-full overflow-hidden bg-slate-950 min-h-[650px] md:min-h-[800px] lg:min-h-[950px] flex items-center pt-24 pb-8 px-8 md:pt-32 md:pb-16 md:px-16 lg:pt-36 lg:pb-20 lg:px-20 shadow-2xl">
    {/* Absolute background image with dark overlay filter */}
    <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-950/60 to-transparent z-10 pointer-events-none"></div>
    <Image
      src={heroImg}
      alt="โรงงานทอปกเสื้อและผลิตเสื้อโปโลครบวงจร ธน พลัส 153"
      widths={[480, 768, 1200]}
      sizes="(max-width: 768px) 100vw, 50vw"
      loading="eager"
      fetchpriority="high"
      class="absolute right-0 top-0 bottom-0 w-full md:w-[60%] lg:w-[50%] h-full object-cover object-top opacity-70 md:opacity-90 z-0 select-none pointer-events-none"
    />

    {/* Left Content Column - White text over dark backdrop */}
    <div class="relative z-20 max-w-2xl text-left flex flex-col items-start">
      <span class="text-xs font-black tracking-widest text-[#FF5A1F] uppercase mb-4 block reveal-up">
        Welcome to Thanaplus 153
      </span>
      
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-white mb-6 leading-[1.1] uppercase reveal-up delay-100">
        Innovative Polo <br/>
        & Uniform Solutions
      </h1>

      <p class="text-gray-300 text-sm sm:text-base md:text-lg max-w-xl leading-relaxed mb-10 font-semibold reveal-up delay-200">
        เราคือโรงงานผลิตเสื้อโปโลพนักงานและยูนิฟอร์มองค์กรแบบครบวงจร ทอปกเสื้อ ตัดเย็บ ปักคอมพิวเตอร์ และสกรีนลายเสื้อด้วยมาตรฐานคุณภาพสูงและราคาตรงจากโรงงาน
      </p>

      {/* Primary Orange Button */}
      <a
        href="/services/#contact"
        class="inline-flex items-center justify-center gap-2.5 bg-[#FF5A1F] hover:bg-[#E04E17] text-white font-black px-8 py-4 rounded-xl shadow-lg shadow-orange-600/10 hover:shadow-orange-600/25 hover:-translate-y-0.5 transition-all duration-300 text-base reveal-up delay-300 pulse-glow"
      >
        <span>Get Your Free Quote</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    {/* Bottom Right Floating Overlay Card - Mockup Style */}
    <div class="absolute bottom-8 right-8 bg-white rounded-2xl p-6 shadow-2xl border border-white/20 max-w-[280px] hidden md:flex flex-col items-start text-left z-20 pointer-events-auto transform hover:-translate-y-0.5 transition-transform reveal-scale delay-500">
      <div class="flex items-center justify-between w-full mb-3 text-[10px] font-black text-gray-400 uppercase tracking-widest">
        <span>1. Manufacturing</span>
        <span class="text-gray-900">01 / 03</span>
      </div>
      <h3 class="text-sm font-black text-gray-900 leading-snug mb-4">
        Customized uniform & embroidery solutions.
      </h3>
      <a href="/products/" class="flex items-center gap-1.5 text-xs font-bold text-gray-900 hover:text-[#FF5A1F] transition-colors">
        <span>What We Need</span>
        <div class="w-6 h-6 rounded-full bg-[#FF5A1F] text-white flex items-center justify-center text-[10px]">
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>
    </div>

  </div>

  {/* 3-Column Stats Divider Panel below the banner - Mockup Style */}
  <div class="w-full bg-white py-10 px-4 sm:px-8 border-b border-gray-150 relative z-10 reveal-up delay-400">
    <div class="max-w-[1000px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 divide-y md:divide-y-0 md:divide-x divide-gray-200">
      
      {/* Stat 1 */}
      <div class="flex flex-col items-center md:items-start md:pl-4 text-center md:text-left">
        <span class="text-3xl lg:text-4xl font-black text-gray-900 tracking-tight"><span class="counter-number" data-target="10">0</span>+ ปี</span>
        <span class="text-xs text-gray-400 font-bold uppercase tracking-widest mt-1.5">ประสบการณ์ผลิตทอและตัดเย็บ</span>
      </div>

      {/* Stat 2 */}
      <div class="flex flex-col items-center md:items-start md:pl-8 text-center md:text-left pt-6 md:pt-0">
        <span class="text-3xl lg:text-4xl font-black text-gray-900 tracking-tight"><span class="counter-number" data-target="500">0</span>+ แบรนด์</span>
        <span class="text-xs text-gray-400 font-bold uppercase tracking-widest mt-1.5">ที่ไว้วางใจผลิตเสื้อกับเรา</span>
      </div>

      {/* Stat 3 */}
      <div class="flex flex-col items-center md:items-start md:pl-8 text-center md:text-left pt-6 md:pt-0">
        <span class="text-3xl lg:text-4xl font-black text-gray-900 tracking-tight"><span class="counter-number" data-target="100">0</span>% QC</span>
        <span class="text-xs text-gray-400 font-bold uppercase tracking-widest mt-1.5">ตรวจเช็คกระดุม ตะเข็บ ฝีเข็ม</span>
      </div>

    </div>
  </div>

</div>

<script>
  function initStatsCounters() {
    const counters = document.querySelectorAll('.counter-number');
    const speed = 1200; // speed duration in ms

    const runCounter = (el: HTMLElement) => {
      const target = parseInt(el.getAttribute('data-target') || '0', 10);
      let count = 0;
      const stepTime = Math.max(Math.floor(speed / target), 12);
      
      const timer = setInterval(() => {
        if (target <= 20) {
          count += 1;
        } else {
          count += Math.ceil(target / 80);
        }
        
        if (count >= target) {
          el.innerText = target.toString();
          clearInterval(timer);
        } else {
          el.innerText = count.toString();
        }
      }, stepTime);
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          runCounter(el);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.1 });

    counters.forEach(c => observer.observe(c));
  }

  // Astro page loads
  document.addEventListener('astro:page-load', initStatsCounters);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStatsCounters);
  } else {
    initStatsCounters();
  }
</script>
