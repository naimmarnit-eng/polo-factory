---
// ServicesHero — ส่วนหัวหน้าบริการ (editorial: eyebrow + headline ใหญ่ + CTA + แถบสถิติ)
// แนวเดียวกับ hero หน้า our-work ของคู่แข่ง แต่คงโทนเทาของเว็บ
import { Button } from '@/components/starwind/button';

interface Props {
  /** จำนวนผลงาน/ตัวอย่างจริง (ดึงจาก collection products) */
  works?: number;
}
const { works = 0 } = Astro.props;

// สถิติความน่าเชื่อถือ — แก้ที่ array เดียว
const stats = [
  { value: '10+', label: 'ปีประสบการณ์' },
  { value: `${works.toLocaleString('th-TH')}+`, label: 'ผลงานที่ส่งมอบ' },
  { value: '100%', label: 'ตรวจ QC ทุกตัว' },
] as const;
---

<section class="relative pt-4 pb-6 lg:pt-8">
  <div class="max-w-3xl">
    <div class="flex items-center gap-2.5 text-xs font-medium tracking-[0.16em] uppercase text-gray-500 mb-5">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-gray-900"></span>
      <span>บริการของเรา · Services</span>
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.05] text-gray-900 mb-6">
      โรงงานรับผลิตเสื้อ<br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-gray-400">
        ครบวงจรในที่เดียว
      </span>
    </h1>

    <p class="text-gray-600 text-lg leading-relaxed mb-8 max-w-2xl">
      ตั้งแต่เลือกเนื้อผ้า ตัดเย็บ ออกแบบ ไปจนถึงงานสกรีนและงานพิมพ์ทุกเทคนิค
      เราดูแลให้ครบทุกขั้นตอนภายใต้มาตรฐานคุณภาพเดียวกัน เพื่อให้แบรนด์ของคุณได้งานที่คมชัด ทนทาน และตรงเวลา
    </p>

    <div class="flex flex-wrap items-center gap-3 mb-12">
      <Button
        href="#contact"
        class="rounded-full bg-gray-900 hover:bg-black text-white px-7 text-base font-semibold shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 gap-2"
      >
        ปรึกษา & ขอใบเสนอราคาฟรี
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </Button>
      <a
        href="/products"
        class="inline-flex items-center rounded-full border border-gray-300 text-gray-900 hover:bg-gray-50 px-7 h-11 text-base font-semibold transition-colors duration-300"
      >
        ดูผลงานของเรา
      </a>
    </div>

    <dl class="flex flex-wrap gap-x-10 gap-y-6 border-t border-gray-200 pt-7">
      {stats.map((s) => (
        <div class="flex flex-col">
          <dt class="text-3xl font-extrabold tracking-tight text-gray-900 tabular-nums">{s.value}</dt>
          <dd class="text-sm text-gray-500 mt-1">{s.label}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
