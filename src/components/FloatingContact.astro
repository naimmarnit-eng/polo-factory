---
import { SITE } from '@/consts';
---

<div class="fixed bottom-6 right-6 z-40 flex flex-col gap-3 items-end pointer-events-none select-none print:hidden">
  
  {/* LINE Floating Button */}
  <a
    href={SITE.contact.lineLink}
    target="_blank"
    rel="noopener noreferrer"
    class="pointer-events-auto flex items-center gap-2 bg-[#06C755] hover:bg-[#05b34c] text-white rounded-full p-3.5 pl-4.5 shadow-2xl hover:shadow-emerald-500/20 hover:-translate-y-1 transition-all duration-300 group cursor-pointer border border-emerald-400/20"
    aria-label="ติดต่อเราทาง LINE"
  >
    <div class="flex items-center gap-2">
      <span class="text-xs font-extrabold tracking-wide max-w-0 overflow-hidden group-hover:max-w-[120px] transition-all duration-500 whitespace-nowrap opacity-0 group-hover:opacity-100">
        คุย LINE ประเมินราคาฟรี
      </span>
      {/* LINE Simple Icon */}
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform duration-300"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
    </div>
    
    {/* Pulsing indicator */}
    <span class="absolute -top-1 -right-1 flex h-3.5 w-3.5">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
      <span class="relative inline-flex rounded-full h-3.5 w-3.5 bg-emerald-100 text-[8px] font-extrabold text-emerald-800 flex items-center justify-center shadow-sm">1</span>
    </span>
  </a>

  {/* Call Floating Button */}
  <a
    href={SITE.contact.phoneLink}
    class="pointer-events-auto flex items-center gap-2 bg-gray-900 hover:bg-black text-white rounded-full p-3.5 pl-4.5 shadow-2xl hover:shadow-gray-900/20 hover:-translate-y-1 transition-all duration-300 group cursor-pointer border border-gray-800"
    aria-label={`โทรติดต่อ ${SITE.contact.phone}`}
  >
    <div class="flex items-center gap-2">
      <span class="text-xs font-extrabold tracking-wide max-w-0 overflow-hidden group-hover:max-w-[120px] transition-all duration-500 whitespace-nowrap opacity-0 group-hover:opacity-100">
        โทร: {SITE.contact.phone}
      </span>
      {/* Call Simple Icon */}
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform duration-300"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    </div>
  </a>

</div>
